//@version=6
strategy("Multi-Session Fair Price", overlay=true,
         margin_long=5, margin_short=5,
         max_lines_count=500, max_labels_count=500, slippage=2)

// ─────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────
i_maxTrades = input.int(4,    "Max trades/session",  minval=1, maxval=10)
i_contBars  = input.int(10,   "Continuation bars",   minval=1, maxval=30)
i_gapPct    = input.float(0.1,"Globex gap min %",    step=0.01, minval=0.0)
i_fomc      = input.bool(true, "FOMC   20:00 CET")

// ─── Calendrier FOMC 20h00 (jour du mois) ─────────────────────────────────────
// 2026 : Jan 28 · Mar 18 · Mai 6 · Jun 17 · Jul 29 · Sep 16 · Oct 28 · Déc 9
i_fomc01 = input.bool(false, "1",  group="📅 FOMC 20h00 (jour du mois)", inline="fm1")
i_fomc02 = input.bool(false, "2",  group="📅 FOMC 20h00 (jour du mois)", inline="fm1")
i_fomc03 = input.bool(false, "3",  group="📅 FOMC 20h00 (jour du mois)", inline="fm1")
i_fomc04 = input.bool(false, "4",  group="📅 FOMC 20h00 (jour du mois)", inline="fm1")
i_fomc05 = input.bool(false, "5",  group="📅 FOMC 20h00 (jour du mois)", inline="fm1")
i_fomc06 = input.bool(false, "6",  group="📅 FOMC 20h00 (jour du mois)", inline="fm1")
i_fomc07 = input.bool(false, "7",  group="📅 FOMC 20h00 (jour du mois)", inline="fm1")
i_fomc08 = input.bool(false, "8",  group="📅 FOMC 20h00 (jour du mois)", inline="fm1")
i_fomc09 = input.bool(false, "9",  group="📅 FOMC 20h00 (jour du mois)", inline="fm1")
i_fomc10 = input.bool(false, "10", group="📅 FOMC 20h00 (jour du mois)", inline="fm1")
i_fomc11 = input.bool(false, "11", group="📅 FOMC 20h00 (jour du mois)", inline="fm2")
i_fomc12 = input.bool(false, "12", group="📅 FOMC 20h00 (jour du mois)", inline="fm2")
i_fomc13 = input.bool(false, "13", group="📅 FOMC 20h00 (jour du mois)", inline="fm2")
i_fomc14 = input.bool(false, "14", group="📅 FOMC 20h00 (jour du mois)", inline="fm2")
i_fomc15 = input.bool(false, "15", group="📅 FOMC 20h00 (jour du mois)", inline="fm2")
i_fomc16 = input.bool(false, "16", group="📅 FOMC 20h00 (jour du mois)", inline="fm2")
i_fomc17 = input.bool(false, "17", group="📅 FOMC 20h00 (jour du mois)", inline="fm2")
i_fomc18 = input.bool(false, "18", group="📅 FOMC 20h00 (jour du mois)", inline="fm2")
i_fomc19 = input.bool(false, "19", group="📅 FOMC 20h00 (jour du mois)", inline="fm2")
i_fomc20 = input.bool(false, "20", group="📅 FOMC 20h00 (jour du mois)", inline="fm2")
i_fomc21 = input.bool(false, "21", group="📅 FOMC 20h00 (jour du mois)", inline="fm3")
i_fomc22 = input.bool(false, "22", group="📅 FOMC 20h00 (jour du mois)", inline="fm3")
i_fomc23 = input.bool(false, "23", group="📅 FOMC 20h00 (jour du mois)", inline="fm3")
i_fomc24 = input.bool(false, "24", group="📅 FOMC 20h00 (jour du mois)", inline="fm3")
i_fomc25 = input.bool(false, "25", group="📅 FOMC 20h00 (jour du mois)", inline="fm3")
i_fomc26 = input.bool(false, "26", group="📅 FOMC 20h00 (jour du mois)", inline="fm3")
i_fomc27 = input.bool(false, "27", group="📅 FOMC 20h00 (jour du mois)", inline="fm3")
i_fomc28 = input.bool(false, "28", group="📅 FOMC 20h00 (jour du mois)", inline="fm3")
i_fomc29 = input.bool(false, "29", group="📅 FOMC 20h00 (jour du mois)", inline="fm3")
i_fomc30 = input.bool(false, "30", group="📅 FOMC 20h00 (jour du mois)", inline="fm3")

// ─── Calendrier News 14h30 (jour du mois) ──────────────────────────────────────
i_news01 = input.bool(false, "1",  group="📅 News 14h30 (jour du mois)", inline="n1")
i_news02 = input.bool(false, "2",  group="📅 News 14h30 (jour du mois)", inline="n1")
i_news03 = input.bool(false, "3",  group="📅 News 14h30 (jour du mois)", inline="n1")
i_news04 = input.bool(false, "4",  group="📅 News 14h30 (jour du mois)", inline="n1")
i_news05 = input.bool(false, "5",  group="📅 News 14h30 (jour du mois)", inline="n1")
i_news06 = input.bool(false, "6",  group="📅 News 14h30 (jour du mois)", inline="n1")
i_news07 = input.bool(false, "7",  group="📅 News 14h30 (jour du mois)", inline="n1")
i_news08 = input.bool(false, "8",  group="📅 News 14h30 (jour du mois)", inline="n1")
i_news09 = input.bool(false, "9",  group="📅 News 14h30 (jour du mois)", inline="n1")
i_news10 = input.bool(false, "10", group="📅 News 14h30 (jour du mois)", inline="n1")
i_news11 = input.bool(false, "11", group="📅 News 14h30 (jour du mois)", inline="n2")
i_news12 = input.bool(false, "12", group="📅 News 14h30 (jour du mois)", inline="n2")
i_news13 = input.bool(false, "13", group="📅 News 14h30 (jour du mois)", inline="n2")
i_news14 = input.bool(false, "14", group="📅 News 14h30 (jour du mois)", inline="n2")
i_news15 = input.bool(false, "15", group="📅 News 14h30 (jour du mois)", inline="n2")
i_news16 = input.bool(false, "16", group="📅 News 14h30 (jour du mois)", inline="n2")
i_news17 = input.bool(false, "17", group="📅 News 14h30 (jour du mois)", inline="n2")
i_news18 = input.bool(false, "18", group="📅 News 14h30 (jour du mois)", inline="n2")
i_news19 = input.bool(false, "19", group="📅 News 14h30 (jour du mois)", inline="n2")
i_news20 = input.bool(false, "20", group="📅 News 14h30 (jour du mois)", inline="n2")
i_news21 = input.bool(false, "21", group="📅 News 14h30 (jour du mois)", inline="n3")
i_news22 = input.bool(false, "22", group="📅 News 14h30 (jour du mois)", inline="n3")
i_news23 = input.bool(false, "23", group="📅 News 14h30 (jour du mois)", inline="n3")
i_news24 = input.bool(false, "24", group="📅 News 14h30 (jour du mois)", inline="n3")
i_news25 = input.bool(false, "25", group="📅 News 14h30 (jour du mois)", inline="n3")
i_news26 = input.bool(false, "26", group="📅 News 14h30 (jour du mois)", inline="n3")
i_news27 = input.bool(false, "27", group="📅 News 14h30 (jour du mois)", inline="n3")
i_news28 = input.bool(false, "28", group="📅 News 14h30 (jour du mois)", inline="n3")
i_news29 = input.bool(false, "29", group="📅 News 14h30 (jour du mois)", inline="n3")
i_news30 = input.bool(false, "30", group="📅 News 14h30 (jour du mois)", inline="n3")

// ─────────────────────────────────────────────────────────
// TIME  (CET = Europe/Paris)
// ─────────────────────────────────────────────────────────
hourCET   = hour(time,   "Europe/Paris")
minuteCET = minute(time, "Europe/Paris")

// ─── Calendrier ───────────────────────────────────────────────────────────────
fomcDays  = array.from(i_fomc01, i_fomc02, i_fomc03, i_fomc04, i_fomc05, i_fomc06, i_fomc07, i_fomc08, i_fomc09, i_fomc10,
                        i_fomc11, i_fomc12, i_fomc13, i_fomc14, i_fomc15, i_fomc16, i_fomc17, i_fomc18, i_fomc19, i_fomc20,
                        i_fomc21, i_fomc22, i_fomc23, i_fomc24, i_fomc25, i_fomc26, i_fomc27, i_fomc28, i_fomc29, i_fomc30)
newsDays  = array.from(i_news01, i_news02, i_news03, i_news04, i_news05, i_news06, i_news07, i_news08, i_news09, i_news10,
                        i_news11, i_news12, i_news13, i_news14, i_news15, i_news16, i_news17, i_news18, i_news19, i_news20,
                        i_news21, i_news22, i_news23, i_news24, i_news25, i_news26, i_news27, i_news28, i_news29, i_news30)
dom       = dayofmonth(time, "Europe/Paris")
isFomcDay = dom <= 30 and array.get(fomcDays, dom - 1)
isNewsDay = dom <= 30 and array.get(newsDays, dom - 1)

// ─────────────────────────────────────────────────────────
// ATR-BASED SL/TP  (ratios conservés pour toutes sessions)
// ─────────────────────────────────────────────────────────
tick    = syminfo.mintick
atr5    = ta.atr(5)
float atrSP = atr5 >= 20 ? 50.0 : atr5 < 7 ? 16.5 : 25.0
float atrTP = atr5 >= 20 ? 75.0 : atr5 < 7 ? 24.75 : 38.5
rrRatio     = atrTP / atrSP   // ≈ 1.5

// ─────────────────────────────────────────────────────────
// CANDLE METRICS
// ─────────────────────────────────────────────────────────
bodyHigh   = math.max(open, close)
bodyLow    = math.min(open, close)
bodySize   = bodyHigh - bodyLow
candleBuy  = close > open
candleSell = open > close
vol        = volume[0]
avgVol     = ta.sma(vol, 5)
// Checklist étape 3 : volume décroissant sur 2-3 bougies
volDecr    = vol[1] < vol[2] and vol[0] < vol[1]

// ─────────────────────────────────────────────────────────
// ÉTAT DE SESSION  (partagé, réinitialisé à chaque session)
// ─────────────────────────────────────────────────────────
var float sv_refC    = na       // close de la bougie de référence
var float sv_refO    = na       // open  de la bougie de référence
var float sv_prevC   = na       // close de référence de la session précédente
var bool  sv_mSell   = false    // tendance 30mn baissière
var bool  sv_mBuy    = false    // tendance 30mn haussière
var int   sv_trades  = 0        // trades pris cette session
var int   sv_bar     = 0        // bougies depuis l'ouverture
var float sv_tHigh   = na       // plus haut des N premières bougies
var float sv_tLow    = na       // plus bas  des N premières bougies
var bool  sv_gapUp   = false    // gap haussier détecté (Globex)
var bool  sv_gapDown = false    // gap baissier détecté (Globex)
var int   sv_sess    = 0        // 1=Globex 2=Japon 3=Londres 4=NY 5=NYLate 6=FOMC

var float[]  sv_str = array.new_float()   // niveaux structurels
var line[]   sv_shL = array.new_line()    // lignes swing high → longs
var line[]   sv_slL = array.new_line()    // lignes swing low  → shorts

var float entry_price = na
var float stop_price  = na
var float tp_price    = na
var float saved_sp    = na    // SL effectif sauvegardé à l'entrée
var float saved_tp    = na    // TP effectif sauvegardé à l'entrée
var line  refLineC    = na
var line  refLineO    = na

// ─────────────────────────────────────────────────────────
// BREAKEVEN & BLOCAGE CONTINUATION
// ─────────────────────────────────────────────────────────
var bool sv_beTriggered     = false  // breakeven déjà déclenché sur ce trade
var bool sv_beIsContTrade   = false  // trade en cours = continuation trade
var bool sv_contTradeOpened = false  // un trade a déjà été pris dans la fenêtre cont.

// ─────────────────────────────────────────────────────────
// DÉFINITION DES SESSIONS  (CET)
// Bougie de référence = 1mn AVANT l'ouverture
// ─────────────────────────────────────────────────────────
// Globex  00h00 → ref 23h59
// Japon   02h00 → ref 01h59
// Londres 09h00 → ref 08h59
// NY      15h30 → ref 15h29  (ou 14h29 les jours de News 14h30)
// NY Late 18h00 → ref 17h59
// FOMC    20h00 → ref 19h59

refGlobex = hourCET == 23 and minuteCET == 59
refJapan  = hourCET ==  1 and minuteCET == 59
refLondon = hourCET ==  8 and minuteCET == 59
refNY     = isNewsDay ? (hourCET == 14 and minuteCET == 29) : (hourCET == 15 and minuteCET == 29)
refNYL    = hourCET == 17 and minuteCET == 59
refFOMC   = i_fomc and isFomcDay and hourCET == 19 and minuteCET == 59
isAnyRef  = refGlobex or refJapan or refLondon or refNY or refNYL or refFOMC

// Fenêtres de trading (90 mn chacune)
inGlobex = hourCET == 0 or (hourCET == 1 and minuteCET <= 29)
inJapan  = hourCET == 2 or (hourCET == 3 and minuteCET <= 29)
inLondon = hourCET == 9 or (hourCET == 10 and minuteCET <= 29)
inNY     = isNewsDay ?
           ((hourCET == 14 and minuteCET >= 30) or hourCET == 15 or (hourCET == 16 and minuteCET == 0)) :
           ((hourCET == 15 and minuteCET >= 30) or hourCET == 16 or (hourCET == 17 and minuteCET == 0))
inNYL    = hourCET == 18 or (hourCET == 19 and minuteCET <= 29)
inFOMC   = i_fomc and isFomcDay and (hourCET == 20 or (hourCET == 21 and minuteCET <= 29))
inAny    = inGlobex or inJapan or inLondon or inNY or inNYL or inFOMC

// ─────────────────────────────────────────────────────────
// RÉINITIALISATION DE SESSION
// ─────────────────────────────────────────────────────────
if isAnyRef
    sv_prevC           := sv_refC
    sv_refC            := close
    sv_refO            := open
    sv_trades          := 0
    sv_bar             := 0
    sv_tHigh           := na
    sv_tLow            := na
    sv_str             := array.new_float()
    sv_shL             := array.new_line()
    sv_slL             := array.new_line()
    sv_contTradeOpened := false

    float tr30 = (close - close[30]) / close[30] * 100
    sv_mSell := tr30 < -0.2
    sv_mBuy  := tr30 > 0.2

    string sessLabel = refGlobex ? "◆GLX" : refJapan ? "◆JAP" : refLondon ? "◆LON" : refNY ? "◆NY" : refNYL ? "◆NYL" : "◆FMC"
    label.new(bar_index, high, text=sessLabel, color=color.gray, textcolor=color.white, size=size.tiny)

    if refGlobex
        sv_sess    := 1
        sv_gapUp   := not na(sv_prevC) and close > sv_prevC * (1.0 + i_gapPct / 100.0)
        sv_gapDown := not na(sv_prevC) and close < sv_prevC * (1.0 - i_gapPct / 100.0)
    else
        sv_gapUp   := false
        sv_gapDown := false
        sv_sess    := refJapan ? 2 : refLondon ? 3 : refNY ? 4 : refNYL ? 5 : 6

// ─────────────────────────────────────────────────────────
// COMPTEUR DE BOUGIES + RANGE DES 10 PREMIÈRES MINUTES
// ─────────────────────────────────────────────────────────
if inAny
    sv_bar := sv_bar + 1
    if sv_bar <= i_contBars
        sv_tHigh := na(sv_tHigh) ? high : math.max(sv_tHigh, high)
        sv_tLow  := na(sv_tLow)  ? low  : math.min(sv_tLow,  low)

// ─────────────────────────────────────────────────────────
// SL/TP EFFECTIFS
// Continuation (i_contBars premières bougies) :
//   SL = longueur de la bougie 10mn (range haut-bas), ratio TP/SL conservé
// Reversion (bougies suivantes) : SL ATR standard
// ─────────────────────────────────────────────────────────
isCont   = inAny and sv_bar > 0 and sv_bar <= i_contBars
tenRange = (na(sv_tHigh) or na(sv_tLow)) ? atrSP : sv_tHigh - sv_tLow
float effSP = (isCont and tenRange > 0) ? tenRange : atrSP
float effTP = effSP * rrRatio

// ─────────────────────────────────────────────────────────
// FILTRES  (checklist 5 étapes)
// ─────────────────────────────────────────────────────────
zoneHigh = math.max(sv_refO, sv_refC)
zoneLow  = math.min(sv_refO, sv_refC)
buffer   = tick * 200

longTime  = inAny and high < sv_refC
shortTime = inAny and low  > sv_refC

var float pushWick = na
if longTime
    pushWick := high - bodyHigh
if shortTime
    pushWick := bodyLow - low

tooMuchWick    = pushWick > bodySize * 0.4
tooCloseOfMean = high >= zoneLow - buffer and low <= zoneHigh + buffer
canTrade       = not tooCloseOfMean

checkWick   = not tooMuchWick
checkTrades = sv_trades < i_maxTrades
checkVol    = vol > avgVol or volDecr

// ─────────────────────────────────────────────────────────
// BIAIS DIRECTIONNEL
// ─────────────────────────────────────────────────────────
bool allowLong  = true
bool allowShort = true

if (sv_sess == 2 or sv_sess == 3) and not na(sv_prevC) and not na(sv_refC)
    allowLong  := sv_refC >= sv_prevC
    allowShort := sv_refC <= sv_prevC

// ─────────────────────────────────────────────────────────
// GLOBEX : trade uniquement si gap détecté
// ─────────────────────────────────────────────────────────
bool globexOk = true
if sv_sess == 1
    globexOk   := not na(sv_prevC) and (sv_gapUp or sv_gapDown)
    allowLong  := sv_gapDown
    allowShort := sv_gapUp

// Blocage re-entrée pendant la fenêtre continuation si un trade a déjà eu lieu
bool contBlocked = isCont and sv_contTradeOpened

// ─────────────────────────────────────────────────────────
// ENTRÉES — TOUCHE D'UNE LIGNE SWING
// ─────────────────────────────────────────────────────────
if array.size(sv_shL) > 0 and strategy.position_size == 0 and not contBlocked and longTime and allowLong and globexOk
    for i = array.size(sv_shL) - 1 to 0
        line  l   = array.get(sv_shL, i)
        float lvl = line.get_y1(l)
        if bodyHigh >= lvl and bodyLow <= lvl
            line.set_x2(l, bar_index)
            line.delete(l)
            array.remove(sv_shL, i)
            if not sv_mSell and canTrade and checkWick and checkTrades and candleBuy and checkVol
                strategy.entry("Long", strategy.long)
                saved_sp           := effSP
                saved_tp           := effTP
                sv_trades          := sv_trades + 1
                sv_beIsContTrade   := isCont
                if isCont
                    sv_contTradeOpened := true

if array.size(sv_slL) > 0 and strategy.position_size == 0 and not contBlocked and shortTime and allowShort and globexOk
    for i = array.size(sv_slL) - 1 to 0
        line  l   = array.get(sv_slL, i)
        float lvl = line.get_y1(l)
        if bodyHigh >= lvl and bodyLow <= lvl
            line.set_x2(l, bar_index)
            line.delete(l)
            array.remove(sv_slL, i)
            if not sv_mBuy and canTrade and checkWick and checkTrades and candleSell and checkVol
                strategy.entry("Short", strategy.short)
                saved_sp           := effSP
                saved_tp           := effTP
                sv_trades          := sv_trades + 1
                sv_beIsContTrade   := isCont
                if isCont
                    sv_contTradeOpened := true

// ─────────────────────────────────────────────────────────
// ENTRÉES — STRUCTURES COUNT (4× BOS confirmé par le body)
// ─────────────────────────────────────────────────────────
if longTime and strategy.position_size == 0 and not contBlocked and not sv_mSell and allowLong and globexOk
    array.push(sv_str, bodyHigh)
    if array.size(sv_str) > 7
        array.shift(sv_str)
    swH = high[1] > high[0] and high[1] > high[2]
    if swH and canTrade
        line lh = line.new(x1=bar_index[1], y1=high[1], x2=bar_index, y2=high[1],
                           color=color.red, style=line.style_dotted)
        array.push(sv_shL, lh)
    if candleBuy
        cnt = 0
        for i = 0 to array.size(sv_str) - 1
            float lvl = array.get(sv_str, i)
            if open < lvl and close > lvl
                cnt := cnt + 1
            else
                cnt := 0
            if cnt == 4 and checkWick and checkTrades and checkVol
                strategy.entry("Long", strategy.long)
                saved_sp           := effSP
                saved_tp           := effTP
                sv_trades          := sv_trades + 1
                sv_beIsContTrade   := isCont
                if isCont
                    sv_contTradeOpened := true
                break

if shortTime and strategy.position_size == 0 and not contBlocked and not sv_mBuy and allowShort and globexOk
    array.push(sv_str, bodyHigh)
    if array.size(sv_str) > 7
        array.shift(sv_str)
    swL = low[1] < low[0] and low[1] < low[2]
    if swL and canTrade
        line ll = line.new(x1=bar_index[1], y1=low[1], x2=bar_index, y2=low[1],
                           color=color.blue, style=line.style_dotted)
        array.push(sv_slL, ll)
    if candleSell
        cnt = 0
        for i = 0 to array.size(sv_str) - 1
            float lvl = array.get(sv_str, i)
            if open > lvl and close < lvl
                cnt := cnt + 1
            else
                cnt := 0
            if cnt == 4 and checkWick and checkTrades and checkVol
                strategy.entry("Short", strategy.short)
                saved_sp           := effSP
                saved_tp           := effTP
                sv_trades          := sv_trades + 1
                sv_beIsContTrade   := isCont
                if isCont
                    sv_contTradeOpened := true
                break

// ─────────────────────────────────────────────────────────
// GESTION SL / TP
// ─────────────────────────────────────────────────────────
if strategy.position_size == 0
    entry_price       := na
    stop_price        := na
    tp_price          := na
    sv_beTriggered    := false
    sv_beIsContTrade  := false

if strategy.position_size > 0 and na(entry_price)
    entry_price := strategy.position_avg_price
    if na(stop_price)
        stop_price := entry_price - saved_sp
    tp_price := entry_price + saved_tp
    label.new(bar_index, high,
              text  = "SL " + str.tostring(math.round(stop_price, 2)),
              color = color.red, textcolor = color.white, size = size.tiny)

if strategy.position_size < 0 and na(entry_price)
    entry_price := strategy.position_avg_price
    if na(stop_price)
        stop_price := entry_price + saved_sp
    tp_price := entry_price - saved_tp
    label.new(bar_index, high,
              text  = "SL " + str.tostring(math.round(stop_price, 2)),
              color = color.red, textcolor = color.white, size = size.tiny)

// ─────────────────────────────────────────────────────────
// BREAKEVEN AUTOMATIQUE — Continuation trade, 1:1 RR atteint
// ─────────────────────────────────────────────────────────
if sv_beIsContTrade and not sv_beTriggered and not na(entry_price)
    if strategy.position_size > 0 and high >= entry_price + saved_sp
        stop_price     := entry_price
        sv_beTriggered := true
        label.new(bar_index, low,
                  text="BE", style=label.style_label_up,
                  color=color.orange, textcolor=color.white, size=size.tiny)
    if strategy.position_size < 0 and low <= entry_price - saved_sp
        stop_price     := entry_price
        sv_beTriggered := true
        label.new(bar_index, high,
                  text="BE", style=label.style_label_down,
                  color=color.orange, textcolor=color.white, size=size.tiny)

strategy.exit("SL/TP LONG",  from_entry="Long",  stop=stop_price, limit=tp_price)
strategy.exit("SL/TP Short", from_entry="Short", stop=stop_price, limit=tp_price)

// ─────────────────────────────────────────────────────────
// LIGNES DE RÉFÉRENCE DE SESSION
// ─────────────────────────────────────────────────────────
if isAnyRef
    refLineC := line.new(x1=bar_index, y1=close, x2=bar_index, y2=close,
                          color=color.green, width=2)
    refLineO := line.new(x1=bar_index, y1=open,  x2=bar_index, y2=open,
                          color=color.green, width=2)

if not na(refLineC) and inAny
    line.set_x2(refLineC, bar_index)
if not na(refLineO) and inAny
    line.set_x2(refLineO, bar_index)

// ─────────────────────────────────────────────────────────
// EXTENSION DES LIGNES SWING ACTIVES
// ─────────────────────────────────────────────────────────
if inAny
    if array.size(sv_shL) > 0
        for i = 0 to array.size(sv_shL) - 1
            line.set_x2(array.get(sv_shL, i), bar_index)
    if array.size(sv_slL) > 0
        for i = 0 to array.size(sv_slL) - 1
            line.set_x2(array.get(sv_slL, i), bar_index)

plot(close)
