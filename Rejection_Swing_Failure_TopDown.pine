//@version=6
strategy("Rejection Swing Failure — Top Down (1H ref)", shorttitle="RSF-TD 1H", overlay=true,
     default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=0,
     process_orders_on_close=true, calc_on_every_tick=false)

// ============================================================================
// INPUTS
// ============================================================================
pivotLen   = input.int(3, "Pivot Lookback (obsolète, non utilisé)", minval=1,
     tooltip="Conservé uniquement pour ne pas décaler les indices in_N sauvegardés sur les graphiques. Les swings 1H utilisent désormais les longueurs gauche/droite du groupe 'Swings 1H (liquidité)'.")
useATRStop = input.bool(true, "Use ATR-based stop", tooltip="If enabled, stop = ATR x multiple beyond the FVG extreme. If disabled, the fixed offset below is used.")
stopOffset = input.float(0.75, "Fixed Stop Offset beyond FVG extreme (points)", minval=0.0, step=0.25,
     tooltip="3 ticks = 0.75 on NQ. Used only when 'Use ATR-based stop' is OFF.")
atrLen     = input.int(14, "ATR Length", minval=1)
atrMult    = input.float(1.5, "ATR Multiple for Stop", minval=0.1, step=0.1)
minRR      = input.float(2.0, "Minimum Reward:Risk", minval=0.1, step=0.1)
flattenHour   = input.int(21, "EOD Flatten Hour (exchange time)", minval=0, maxval=23,
     tooltip="No overnight positions: any open trade is closed at this time, and no new setups are armed after it.")
flattenMinute = input.int(45, "EOD Flatten Minute", minval=0, maxval=59)
fridayFlattenHour   = input.int(15, "Friday Flatten Hour (exchange time)", minval=0, maxval=23,
     tooltip="The Globex electronic session for NQ closes around 16:00 exchange time on Fridays, before the regular EOD flatten time would ever trigger. Use this earlier cutoff on Fridays so positions are closed before the weekend instead of carrying over.")
fridayFlattenMinute = input.int(45, "Friday Flatten Minute", minval=0, maxval=59)

// ─── Webhook : alertes JSON vers le dispatcher FastAPI (state_manager) ───────
// Déclarés en dernier pour ne pas décaler les indices in_N sauvegardés sur les
// graphiques. Webhook actif → le payload JSON remplace les alertes texte.
// Créer UNE alerte TradingView « Toute fonction alert() » avec l'URL du VPS.
grpWebhook = "Webhook"
useWebhook = input.bool(false, "Alertes webhook JSON", group=grpWebhook)
whSecret   = input.string("CHANGE_ME", "Secret partagé", group=grpWebhook, tooltip="Doit correspondre au secret attendu par le serveur FastAPI")
whStrat    = input.string("RSF_TD", "Identifiant stratégie", group=grpWebhook)

// ─── TP structurel : liquidité 1H la plus proche ────────────────────────────
// Déclarés en dernier, comme tous les nouveaux inputs (indices in_N sauvegardés
// sur les graphiques).
grpTP = "Take Profit"
useSwingTP = input.bool(true, "TP = liquidité 1H non mitigée la plus proche au-delà de l'entrée", group=grpTP,
     tooltip="TP posé sur le swing 1H NON MITIGÉ (jamais retouché par le prix) le plus proche au-delà du prix d'entrée dans le sens du trade — de la liquidité encore en place, pas un niveau déjà consommé. S'il n'en existe aucun, pas de trade. Désactivé : TP = liquidité opposée connue au moment du setup (comportement précédent).")
maxSwingKeep = input.int(30, "Swings 1H mémorisés (par côté)", minval=5, group=grpTP,
     tooltip="Taille de l'historique de niveaux de liquidité 1H non mitigés gardé en mémoire (les plus anciens sont oubliés au-delà).")

// ─── Swings 1H façon « Swing Points and Liquidity » (Leviathan) ──────────────
// Un swing point n'est de la liquidité QUE tant qu'il n'a pas été rempli :
// dès qu'une bougie 1H traverse le niveau, il est retiré de la mémoire
// (extend until fill). Pivots asymétriques comme dans le script d'origine.
grpSwing = "Swings 1H (liquidité)"
swingSizeL = input.int(15, "Barres à GAUCHE du swing (1H)", minval=1, group=grpSwing,
     tooltip="Nombre de bougies 1H plus basses (pour un swing high) requises à gauche du pivot. Défaut 15, comme le script Leviathan.")
swingSizeR = input.int(10, "Barres à DROITE du swing (1H)", minval=1, group=grpSwing,
     tooltip="Nombre de bougies 1H requises à droite pour CONFIRMER le pivot. 10 = défaut Leviathan (confirmation 10 h après l'extrême). Testé le 16/07 sur la fenêtre juin-juillet : R=10 → 8 trades, R=5 → 1, R=8 → 0 — paramètre très sensible, à valider sur un historique long.")

whNum(float v) =>
    na(v) ? 'null' : str.tostring(math.round_to_mintick(v))

// La taille réelle par compte vient du serveur (accounts.json) ; qty=1 indicatif.
whAlert(string action, float slLvl, float tpLvl) =>
    if useWebhook
        msg = '{"secret":"' + whSecret
         + '","strategy":"' + whStrat
         + '","symbol":"' + syminfo.root
         + '","ticker":"' + syminfo.tickerid
         + '","action":"' + action
         + '","tradeType":"rsf"'
         + ',"qty":1'
         + ',"price":' + str.tostring(math.round_to_mintick(close))
         + ',"stopLoss":' + whNum(slLvl)
         + ',"takeProfit":' + whNum(tpLvl)
         + ',"time":"' + str.format_time(timenow, 'yyyy-MM-dd HH:mm:ss', 'Europe/Paris') + '"}'
        alert(msg, alert.freq_once_per_bar)

// ============================================================================
// 1) DONNÉES 1H — dernière bougie 1H entièrement clôturée
//    With lookahead_off, "open/high/low/close/time_close" of "60" already
//    refer to the LAST FULLY CLOSED 1H bar as soon as it closes.
// ============================================================================
h1_open      = request.security(syminfo.tickerid, "60", open,       lookahead=barmerge.lookahead_off)
h1_high      = request.security(syminfo.tickerid, "60", high,       lookahead=barmerge.lookahead_off)
h1_low       = request.security(syminfo.tickerid, "60", low,        lookahead=barmerge.lookahead_off)
h1_close     = request.security(syminfo.tickerid, "60", close,      lookahead=barmerge.lookahead_off)
h1_closePrev = request.security(syminfo.tickerid, "60", close[1],   lookahead=barmerge.lookahead_off)
h1_timeClose = request.security(syminfo.tickerid, "60", time_close, lookahead=barmerge.lookahead_off)

// Fires once, on the 5m bar right after a new 1H bar has closed
h1_newBar = ta.change(h1_timeClose) != 0

h1_red   = h1_close < h1_open
h1_green = h1_close > h1_open

// ============================================================================
// 2) SWING POINTS 1H + LIQUIDITÉ (logique « Swing Points and Liquidity »,
//    Leviathan) — pivots asymétriques L/R confirmés sans repaint ; chaque
//    swing confirmé devient un niveau de liquidité mémorisé JUSQU'À CE QUE le
//    prix le traverse (fill) : une bougie 1H dont le high atteint un swing
//    high (resp. low ≤ swing low) consomme le niveau, qui est retiré.
//    L'évaluation se fait à la clôture de chaque bougie 1H.
// ============================================================================
f_swings() =>
    ph = ta.pivothigh(high, swingSizeL, swingSizeR)
    pl = ta.pivotlow(low,  swingSizeL, swingSizeR)
    [ph, pl]

[h1PH, h1PL] = request.security(syminfo.tickerid, "60", f_swings(), lookahead=barmerge.lookahead_off)

var array<float> liqHighs = array.new_float()
var array<float> liqLows  = array.new_float()

// (a) Nouveau pivot 1H confirmé sur la bougie 1H qui vient de clôturer → empilé
if h1_newBar and not na(h1PH)
    array.push(liqHighs, h1PH)
    if array.size(liqHighs) > maxSwingKeep
        array.shift(liqHighs)
if h1_newBar and not na(h1PL)
    array.push(liqLows, h1PL)
    if array.size(liqLows) > maxSwingKeep
        array.shift(liqLows)

// Niveau de liquidité NON MITIGÉ le plus proche au-dessus / en-dessous d'un prix.
nearestSwingAbove(float level) =>
    float nearest = na
    if array.size(liqHighs) > 0
        for i = 0 to array.size(liqHighs) - 1
            p = array.get(liqHighs, i)
            if p > level and (na(nearest) or p < nearest)
                nearest := p
    nearest

nearestSwingBelow(float level) =>
    float nearest = na
    if array.size(liqLows) > 0
        for i = 0 to array.size(liqLows) - 1
            p = array.get(liqLows, i)
            if p < level and (na(nearest) or p > nearest)
                nearest := p
    nearest

// (b) Référence du setup : liquidité la plus proche au-delà de la clôture 1H
//     PRÉCÉDENTE — le niveau était donc encore intact avant cette bougie
//     (l'ancien filtre « fresh breakout » est de fait intégré).
nearestLiqHigh = h1_newBar ? nearestSwingAbove(h1_closePrev) : na
nearestLiqLow  = h1_newBar ? nearestSwingBelow(h1_closePrev) : na

// ============================================================================
// EOD FLATTEN — day-trading only, no overnight positions.
//    No new setup is armed at/after the flatten time, and any open position
//    is force-closed at the flatten time.
// ============================================================================
newTradingDay = ta.change(time("D")) != 0

// On Fridays, use the earlier Friday cutoff (close to the Globex session end)
// instead of the regular EOD flatten time, so the position is closed before
// the weekend gap rather than carrying over to Sunday's reopen.
isFriday = dayofweek == dayofweek.friday
regularFlatten = isFriday ?
     (hour > fridayFlattenHour or (hour == fridayFlattenHour and minute >= fridayFlattenMinute)) :
     (hour == flattenHour and minute >= flattenMinute)

// Safety net: if a position is still open when a new trading day starts
// (e.g. a holiday or data gap meant neither flatten condition above fired),
// flatten it on the first bar of the new day instead of waiting further.
eodFlatten = regularFlatten or (newTradingDay and strategy.position_size != 0)

// ============================================================================
// 3) SETUP — REJET AU SWING 1H NON MITIGÉ LE PLUS PROCHE
//    La bougie 1H balaie la liquidité la plus proche (high au-delà du swing
//    high intact le plus proche) puis REFERME de l'autre côté = rejet / SFP.
//    Si elle clôture au-delà du niveau (acceptation), pas de setup — et le
//    niveau est de toute façon consommé par l'étape (c) ci-dessous.
// ============================================================================
bearishSetup = h1_newBar and not na(nearestLiqHigh) and h1_high > nearestLiqHigh and h1_close < nearestLiqHigh and h1_red and not eodFlatten
bullishSetup = h1_newBar and not na(nearestLiqLow)  and h1_low  < nearestLiqLow  and h1_close > nearestLiqLow  and h1_green and not eodFlatten

// (c) Mitigation « extend until fill » : tout niveau traversé par la bougie 1H
//     qui vient de clôturer est consommé — balayé-rejeté ou accepté, sa
//     liquidité est prise, il ne peut plus servir ni de setup ni de TP.
//     (Après la détection du setup, qui a besoin du niveau encore présent.)
if h1_newBar
    if array.size(liqHighs) > 0
        for i = array.size(liqHighs) - 1 to 0
            if h1_high >= array.get(liqHighs, i)
                array.remove(liqHighs, i)
    if array.size(liqLows) > 0
        for i = array.size(liqLows) - 1 to 0
            if h1_low <= array.get(liqLows, i)
                array.remove(liqLows, i)

// ============================================================================
// 4) PENDING SETUP STATE
//    A valid 1H signal arms a "wait for FVG" state. The first FVG found on
//    the 5m chart (current timeframe) in the matching direction triggers the
//    trade decision (take it, or skip if RR < minRR). Either way the pending
//    state is cleared after the first FVG.
// ============================================================================
var int   pendingDir    = 0     // 1 = waiting for bullish FVG (long), -1 = waiting for bearish FVG (short)
var float pendingTarget = na    // liquidité opposée connue au moment du setup (TP historique)

if bearishSetup
    pendingDir    := -1
    pendingTarget := nearestLiqLow
if bullishSetup
    pendingDir    := 1
    pendingTarget := nearestLiqHigh

// ============================================================================
// 5) 5-MINUTE FVG DETECTION (current chart timeframe)
//    Bullish FVG: low[0]  > high[2]  (gap up)
//    Bearish FVG: high[0] < low[2]   (gap down)
// ============================================================================
bullFVG = low > high[2]
bearFVG = high < low[2]

// Most extreme price across the 3 candles forming the FVG -> used for the stop
fvgHighestHigh = math.max(high, math.max(high[1], high[2]))
fvgLowestLow   = math.min(low,  math.min(low[1],  low[2]))

// Stop distance: ATR x multiple (current timeframe) or fixed offset
atrVal       = ta.atr(atrLen)
stopDistance = useATRStop ? atrVal * atrMult : stopOffset

// ============================================================================
// 6) ENTRY LOGIC — entry at close of the FVG candle
//    Stop  = stopDistance (ATR x multiple, or fixed offset) beyond the most extreme FVG candle
//    Target (useSwingTP) = liquidité 1H NON MITIGÉE la plus proche au-delà de
//    l'entrée dans le sens du trade ; sinon liquidité opposée figée au setup.
//    Trade pris seulement si RR >= minRR.
// ============================================================================
var float activeTp = na

if strategy.position_size == 0 and pendingDir == 1 and bullFVG
    entryPrice = close
    stopPrice  = fvgLowestLow - stopDistance
    target     = useSwingTP ? nearestSwingAbove(entryPrice) : pendingTarget
    risk       = entryPrice - stopPrice
    reward     = target - entryPrice
    rr         = risk > 0 ? reward / risk : na

    if risk > 0 and not na(target) and rr >= minRR
        strategy.entry("Long", strategy.long, comment="RSF Long")
        strategy.exit("Long Exit", from_entry="Long", stop=stopPrice, limit=target)
        activeTp := target
        whAlert('buy', stopPrice, target)
        if not useWebhook
            alert("RSF-TD LONG @ " + str.tostring(entryPrice, format.mintick) +
              " | SL " + str.tostring(stopPrice, format.mintick) +
              " | TP " + str.tostring(target, format.mintick), alert.freq_once_per_bar_close)
    pendingDir := 0

if strategy.position_size == 0 and pendingDir == -1 and bearFVG
    entryPrice = close
    stopPrice  = fvgHighestHigh + stopDistance
    target     = useSwingTP ? nearestSwingBelow(entryPrice) : pendingTarget
    risk       = stopPrice - entryPrice
    reward     = entryPrice - target
    rr         = risk > 0 ? reward / risk : na

    if risk > 0 and not na(target) and rr >= minRR
        strategy.entry("Short", strategy.short, comment="RSF Short")
        strategy.exit("Short Exit", from_entry="Short", stop=stopPrice, limit=target)
        activeTp := target
        whAlert('sell', stopPrice, target)
        if not useWebhook
            alert("RSF-TD SHORT @ " + str.tostring(entryPrice, format.mintick) +
              " | SL " + str.tostring(stopPrice, format.mintick) +
              " | TP " + str.tostring(target, format.mintick), alert.freq_once_per_bar_close)
    pendingDir := 0

// Force-close any open position at the EOD flatten time (no overnight holding)
if strategy.position_size != 0 and eodFlatten
    whAlert('flatten', float(na), float(na))
    strategy.close_all(comment="EOD Flatten")
    pendingDir := 0

// Trade terminé → on oublie le TP actif (transition position ouverte → flat,
// pas "== 0" brut : sur la bougie d'entrée, position_size vaut encore 0 et
// l'affectation faite juste au-dessus serait effacée).
if strategy.position_size == 0 and strategy.position_size[1] != 0
    activeTp := na

// ============================================================================
// VISUALS — liquidité 1H intacte la plus proche de part et d'autre du prix
// ============================================================================
liqHighDisp = nearestSwingAbove(close)
liqLowDisp  = nearestSwingBelow(close)
plot(liqHighDisp, "Liquidité 1H au-dessus", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=1)
plot(liqLowDisp,  "Liquidité 1H en-dessous", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=1)

// TP actif (liquidité 1H visée) pendant le trade
plot(strategy.position_size != 0 ? activeTp : na, "TP actif (liquidité 1H)",
     color=color.new(color.orange, 0), style=plot.style_linebr, linewidth=1)

plotshape(bearishSetup, title="Bearish Setup (waiting FVG)", style=shape.triangledown,
     location=location.abovebar, color=color.red, size=size.small)
plotshape(bullishSetup, title="Bullish Setup (waiting FVG)", style=shape.triangleup,
     location=location.belowbar, color=color.green, size=size.small)
