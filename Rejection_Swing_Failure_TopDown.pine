//@version=6
strategy("Rejection Swing Failure — Top Down (1H ref)", shorttitle="RSF-TD 1H", overlay=true,
     default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=0,
     process_orders_on_close=true, calc_on_every_tick=false)

// ============================================================================
// INPUTS
// ============================================================================
pivotLen   = input.int(3, "Pivot Lookback (bars each side, 1H)", minval=1)
useATRStop = input.bool(true, "Use ATR-based stop", tooltip="If enabled, stop = ATR x multiple beyond the FVG extreme. If disabled, the fixed offset below is used.")
stopOffset = input.float(0.75, "Fixed Stop Offset beyond FVG extreme (points)", minval=0.0, step=0.25,
     tooltip="3 ticks = 0.75 on NQ. Used only when 'Use ATR-based stop' is OFF.")
atrLen     = input.int(14, "ATR Length", minval=1)
atrMult    = input.float(1.5, "ATR Multiple for Stop", minval=0.1, step=0.1)
minRR      = input.float(2.0, "Minimum Reward:Risk", minval=0.1, step=0.1)
flattenHour   = input.int(21, "EOD Flatten Hour (exchange time)", minval=0, maxval=23,
     tooltip="No overnight positions: any open trade is closed at this time, and no new setups are armed after it.")
flattenMinute = input.int(45, "EOD Flatten Minute", minval=0, maxval=59)
fridayFlattenHour   = input.int(15, "Friday Flatten Hour (exchange time)", minval=0, maxval=23,
     tooltip="The Globex electronic session for NQ closes around 16:00 exchange time on Fridays, before the regular EOD flatten time would ever trigger. Use this earlier cutoff on Fridays so positions are closed before the weekend instead of carrying over.")
fridayFlattenMinute = input.int(45, "Friday Flatten Minute", minval=0, maxval=59)

// ============================================================================
// 1) 1H TIMEFRAME — most recent confirmed pivot high / pivot low
//    Référence de temps passée du Daily au 1H : un pivot 1H se confirme en
//    `pivotLen` heures (≈3 h) au lieu de 3 jours pour le daily — supprime le
//    retard de confirmation. ta.pivothigh/pivotlow ne se mettent à jour qu'une
//    fois le pivot réellement confirmé (pas de repaint).
//    dPH/dPL contiennent désormais des pivots 1H (nom conservé pour simplicité).
// ============================================================================
f_lastPivot() =>
    var float lastPH = na
    var float lastPL = na
    ph = ta.pivothigh(high, pivotLen, pivotLen)
    pl = ta.pivotlow(low, pivotLen, pivotLen)
    if not na(ph)
        lastPH := ph
    if not na(pl)
        lastPL := pl
    [lastPH, lastPL]

[dPH, dPL] = request.security(syminfo.tickerid, "60", f_lastPivot(), lookahead=barmerge.lookahead_off)

// ============================================================================
// 2) 1H TIMEFRAME — breakout d'un pivot 1H + rejet à la clôture de bougie
//    Le pivot 1H (dPH/dPL ci-dessus) est confirmé ≥ pivotLen heures plus tôt ;
//    une bougie 1H ULTÉRIEURE qui le balaie puis referme de l'autre côté = SFP.
//    With lookahead_off, "open/high/low/close/time_close" of "60" already
//    refer to the LAST FULLY CLOSED 1H bar as soon as it closes.
// ============================================================================
h1_open      = request.security(syminfo.tickerid, "60", open,       lookahead=barmerge.lookahead_off)
h1_high      = request.security(syminfo.tickerid, "60", high,       lookahead=barmerge.lookahead_off)
h1_low       = request.security(syminfo.tickerid, "60", low,        lookahead=barmerge.lookahead_off)
h1_close     = request.security(syminfo.tickerid, "60", close,      lookahead=barmerge.lookahead_off)
h1_closePrev = request.security(syminfo.tickerid, "60", close[1],   lookahead=barmerge.lookahead_off)
h1_timeClose = request.security(syminfo.tickerid, "60", time_close, lookahead=barmerge.lookahead_off)

// Fires once, on the 5m bar right after a new 1H bar has closed
h1_newBar = ta.change(h1_timeClose) != 0

h1_red   = h1_close < h1_open
h1_green = h1_close > h1_open

// ============================================================================
// EOD FLATTEN — day-trading only, no overnight positions.
//    No new setup is armed at/after the flatten time, and any open position
//    is force-closed at the flatten time.
// ============================================================================
newTradingDay = ta.change(time("D")) != 0

// On Fridays, use the earlier Friday cutoff (close to the Globex session end)
// instead of the regular EOD flatten time, so the position is closed before
// the weekend gap rather than carrying over to Sunday's reopen.
isFriday = dayofweek == dayofweek.friday
regularFlatten = isFriday ?
     (hour > fridayFlattenHour or (hour == fridayFlattenHour and minute >= fridayFlattenMinute)) :
     (hour == flattenHour and minute >= flattenMinute)

// Safety net: if a position is still open when a new trading day starts
// (e.g. a holiday or data gap meant neither flatten condition above fired),
// flatten it on the first bar of the new day instead of waiting further.
eodFlatten = regularFlatten or (newTradingDay and strategy.position_size != 0)

// "Fresh breakout" filter: the PREVIOUS 1H bar must have closed on the other side
// of the pivot. This rejects setups where price has already been trading past
// the pivot for a while (stale level) and only requires a momentary wick through
// an old, far-away level to fire.
freshBreakoutBear = h1_closePrev < dPH
freshBreakoutBull = h1_closePrev > dPL

// Breakout ABOVE 1H pivot high, then close back BELOW it on a RED candle -> bearish (short) setup
bearishSetup = h1_newBar and not na(dPH) and h1_high > dPH and h1_close < dPH and h1_red and freshBreakoutBear and not eodFlatten

// Breakout BELOW 1H pivot low, then close back ABOVE it on a GREEN candle -> bullish (long) setup
bullishSetup = h1_newBar and not na(dPL) and h1_low < dPL and h1_close > dPL and h1_green and freshBreakoutBull and not eodFlatten

// ============================================================================
// 3) PENDING SETUP STATE
//    A valid 1H signal arms a "wait for FVG" state. The first FVG found on
//    the 5m chart (current timeframe) in the matching direction triggers the
//    trade decision (take it, or skip if RR < minRR). Either way the pending
//    state is cleared after the first FVG.
// ============================================================================
var int   pendingDir    = 0     // 1 = waiting for bullish FVG (long), -1 = waiting for bearish FVG (short)
var float pendingTarget = na    // opposite 1H pivot -> take-profit target

if bearishSetup
    pendingDir    := -1
    pendingTarget := dPL
if bullishSetup
    pendingDir    := 1
    pendingTarget := dPH

// ============================================================================
// 4) 5-MINUTE FVG DETECTION (current chart timeframe)
//    Bullish FVG: low[0]  > high[2]  (gap up)
//    Bearish FVG: high[0] < low[2]   (gap down)
// ============================================================================
bullFVG = low > high[2]
bearFVG = high < low[2]

// Most extreme price across the 3 candles forming the FVG -> used for the stop
fvgHighestHigh = math.max(high, math.max(high[1], high[2]))
fvgLowestLow   = math.min(low,  math.min(low[1],  low[2]))

// Stop distance: ATR x multiple (current timeframe) or fixed offset
atrVal       = ta.atr(atrLen)
stopDistance = useATRStop ? atrVal * atrMult : stopOffset

// ============================================================================
// 5) ENTRY LOGIC — entry at close of the FVG candle
//    Stop  = stopDistance (ATR x multiple, or fixed offset) beyond the most extreme FVG candle
//    Target = opposite 1H pivot, only if RR >= minRR, otherwise skip trade
// ============================================================================
if strategy.position_size == 0 and pendingDir == 1 and bullFVG
    entryPrice = close
    stopPrice  = fvgLowestLow - stopDistance
    target     = pendingTarget
    risk       = entryPrice - stopPrice
    reward     = target - entryPrice
    rr         = risk > 0 ? reward / risk : na

    if risk > 0 and not na(target) and rr >= minRR
        strategy.entry("Long", strategy.long, comment="RSF Long")
        strategy.exit("Long Exit", from_entry="Long", stop=stopPrice, limit=target)
        alert("RSF-TD LONG @ " + str.tostring(entryPrice, format.mintick) +
              " | SL " + str.tostring(stopPrice, format.mintick) +
              " | TP " + str.tostring(target, format.mintick), alert.freq_once_per_bar_close)
    pendingDir := 0

if strategy.position_size == 0 and pendingDir == -1 and bearFVG
    entryPrice = close
    stopPrice  = fvgHighestHigh + stopDistance
    target     = pendingTarget
    risk       = stopPrice - entryPrice
    reward     = entryPrice - target
    rr         = risk > 0 ? reward / risk : na

    if risk > 0 and not na(target) and rr >= minRR
        strategy.entry("Short", strategy.short, comment="RSF Short")
        strategy.exit("Short Exit", from_entry="Short", stop=stopPrice, limit=target)
        alert("RSF-TD SHORT @ " + str.tostring(entryPrice, format.mintick) +
              " | SL " + str.tostring(stopPrice, format.mintick) +
              " | TP " + str.tostring(target, format.mintick), alert.freq_once_per_bar_close)
    pendingDir := 0

// Force-close any open position at the EOD flatten time (no overnight holding)
if strategy.position_size != 0 and eodFlatten
    strategy.close_all(comment="EOD Flatten")
    pendingDir := 0

// ============================================================================
// VISUALS
// ============================================================================
plot(dPH, "1H Pivot High", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=1)
plot(dPL, "1H Pivot Low",  color=color.new(color.green, 0), style=plot.style_linebr, linewidth=1)

plotshape(bearishSetup, title="Bearish Setup (waiting FVG)", style=shape.triangledown,
     location=location.abovebar, color=color.red, size=size.small)
plotshape(bullishSetup, title="Bullish Setup (waiting FVG)", style=shape.triangleup,
     location=location.belowbar, color=color.green, size=size.small)
