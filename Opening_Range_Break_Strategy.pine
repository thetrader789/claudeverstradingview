//@version=6
strategy("Opening Range Break Strategy (ORB) — Anti Fake-Breakout", shorttitle="ORB Anti-Fake", overlay=true,
     default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=0,
     process_orders_on_close=true, calc_on_every_tick=false, slippage=3, max_boxes_count=500)

// ============================================================================
// Adapté de la présentation "Opening Range Break Strategy" (slides 1-7).
// Règle clé du slide 5 (invalidation) : on évite un breakout qui se produit
// trop près du H/L de la session précédente ET qui n'a pas d'autre liquidité
// (swing high/low) au-delà pour justifier une vraie continuation — sinon
// c'est typiquement un fake breakout basse probabilité.
// ============================================================================

// ============================================================================
// INPUTS — Session / Opening Range
// ============================================================================
grpSession = "Session & Opening Range"
sessionChoice = input.string("Japon + Londres + New York", "Session",
     options=["Japon + Londres + New York", "New York seule (15:30-15:45)", "Londres seule (09:00-09:30)", "Japon seule (02:00-02:25)", "Personnalisée"],
     group=grpSession,
     tooltip="Le mode multi-sessions trade les trois opening ranges de la journée (Japon 02:00-02:25, Londres 09:00-09:30, New York 15:30-15:45, heure de Paris). Leurs fenêtres de recherche (maxSessionHours) ne se chevauchent jamais : chaque nouvelle session réinitialise le range et les compteurs de session. Les limites journalières (pertes max / stop après gain) restent globales sur la journée. L'OR Japon se ferme à 02:25 (et non 02:30) pour que la première bougie de cassure éligible clôture à 02:30 pile — aucune entrée ne peut être exécutée avant 02:30.")
customSession = input.session("1530-1545", "Session personnalisée (si 'Personnalisée')", group=grpSession)
sessionTZ = input.string("Europe/Paris", "Fuseau horaire de la session (CET/CEST)", group=grpSession,
     tooltip="Fuseau IANA (pas un offset fixe) : bascule automatiquement CET (hiver, GMT+1) / CEST (été, GMT+2). Un offset fixe type 'GMT+1' se décale d'1h dès qu'on change d'heure. Ce script doit être appliqué sur un graphique en 5 minutes (règle 'clôture 5m hors range').")

// ============================================================================
// INPUTS — Filtre anti fake-breakout (slide 5)
// ============================================================================
grpInvalid = "Filtre anti fake-breakout (slide 5)"
usePrevSessionFilter = input.bool(true, "Vérifier proximité H/L session précédente", group=grpInvalid)
useSwingFilter = input.bool(true, "Exiger de la liquidité (swing) au-delà du niveau", group=grpInvalid)
atrLen = input.int(14, "Période ATR (mesure de proximité)", group=grpInvalid)
proximityMult = input.float(0.5, "Distance min. requise (x ATR)", group=grpInvalid,
     tooltip="Si le high/low de l'OR est à moins de X x ATR du H/L de la session précédente ET qu'aucun swing significatif ne se trouve au-delà à plus de X x ATR, le trade est invalidé (fake breakout probable).")
pivotLen = input.int(8, "Longueur pivot (barres de chaque côté)", group=grpInvalid)
pivotLookback = input.int(300, "Barres de recherche des pivots", group=grpInvalid)

// ============================================================================
// INPUTS — Gestion du trade
// ============================================================================
grpTrade = "Gestion du trade"
minRR = input.float(1.0, "R:R minimum pour entrée marché (sinon pas de trade)", group=grpTrade,
     tooltip="Si le R:R offert par la bougie de breakout est inférieur à ce seuil, aucun trade n'est pris (pas de retest ni d'ordre en attente).")
maxLossesDay = input.int(2, "Pertes max par jour", group=grpTrade)
stopAfterWin = input.bool(true, "Stop trading après 1 gain dans la journée", group=grpTrade)
maxSessionHours = input.float(3.0, "Durée max de recherche de breakout après clôture OR (heures)", group=grpTrade,
     tooltip="Passé ce délai après la fin de l'opening range, on arrête de chercher un breakout sur ce range jusqu'à la prochaine session.")

grpFlatten = "Sécurité"
useEodFlatten = input.bool(true, "Flatten de sécurité en fin de séance", group=grpFlatten)
flattenHour = input.int(16, "Heure de flatten (heure de l'EXCHANGE du symbole)", minval=0, maxval=23, group=grpFlatten,
     tooltip="ATTENTION : la variable Pine 'hour' est dans le fuseau de l'exchange, pas celui du graphique. COMEX (GC) = New York : 16h45 → position fermée juste avant la clôture quotidienne de 17h00 ET (conformité prop firm : flat avant la fin de séance). CME (NQ/MNQ) = Chicago : mettre 15 (15h45 CT). L'ancien défaut 23h00 tombait APRÈS la clôture de séance et ne fermait rien d'utile.")
flattenMinute = input.int(45, "Minute de flatten", minval=0, maxval=59, group=grpFlatten,
     tooltip="Le flatten est actif de flattenHour:flattenMinute jusqu'à la fin de cette heure-là (ex. 16:45 → fenêtre 16:45-16:59, soit 3 bougies de 5 min avant la clôture — marge si une bougie manque).")

// Déclaré en DERNIER volontairement : ajouter un input au milieu décale les
// indices in_N et fait réappliquer les valeurs sauvegardées du graphique aux
// mauvais champs. (Affiché dans le groupe "Gestion du trade" malgré tout.)
disableLongsJapanLondon = input.bool(false, "Pas de longs sur Japon et Londres", group=grpTrade,
     tooltip="En backtest, les longs pris sur les opening ranges Japon et Londres sont largement perdants (les shorts portent la performance). Actif aussi en mode session seule Japon/Londres. Les longs restent autorisés sur New York et en session personnalisée.")
tpProximityTicks = input.int(10, "Tolérance TP (ticks) — clôture proche du swing = sortie", minval=0, group=grpTrade,
     tooltip="Si une bougie CLÔTURE à moins de X ticks du swing cible sans que la limite ait été touchée, on ferme le trade au marché sur cette clôture plutôt que d'exiger le tick exact (cas du 18 juin : pic à quelques ticks sous le TP puis retournement jusqu'au stop). 0 = désactivé. GC : 1 tick = 0,1 pt ; NQ : 1 tick = 0,25 pt.")
dynamicTpFollow = input.bool(false, "TP dynamique (suit les nouveaux swings formés après l'entrée)", group=grpTrade,
     tooltip="Par défaut le TP est figé au swing le plus proche connu à la bougie de cassure, même s'il est lointain — un trade peut alors courir des heures et chevaucher la session suivante. Activé : à chaque nouveau swing confirmé plus proche dans le sens du trade, la limite est déplacée dessus (elle ne peut que se rapprocher, jamais s'éloigner). Seuls comptent les swings formés APRÈS la bougie d'entrée et au-delà du prix d'entrée d'au moins la distance min. (x ATR) : un micro-swing qui vient de se faire au niveau de l'entrée n'est pas une cible, le TP initial reste le swing récent établi. Le stop (orMid figé à l'entrée) n'est jamais modifié.")

// ============================================================================
// 1) SESSION & OPENING RANGE
// ============================================================================
// Le multi-sessions est le fallback : toute valeur non reconnue (ex. ancienne
// option sauvegardée sur le graphique avant un renommage) retombe dessus,
// plutôt que sur la session personnalisée qui masquerait silencieusement le
// mode demandé. Trois appels time() distincts (pas une session string à
// virgules, dont le support n'est pas fiable) combinés en OR.
singleSessionString = sessionChoice == "Personnalisée" ? customSession :
     sessionChoice == "New York seule (15:30-15:45)" ? "1530-1545" :
     sessionChoice == "Londres seule (09:00-09:30)" ? "0900-0930" :
     sessionChoice == "Japon seule (02:00-02:25)" ? "0200-0225" : ""
isMultiSession = singleSessionString == ""

// L'OR Japon ferme à 02:25 (pas 02:30) volontairement : la première bougie
// "hors session" (donc éligible à une cassure) est celle ouverte à 02:25 et
// clôturée à 02:30 — avec process_orders_on_close=true, l'entrée la plus
// précoce possible s'exécute à 02:30 pile, jamais avant.
inJapanOR  = not na(time(timeframe.period, "0200-0225", sessionTZ))
inLondonOR = not na(time(timeframe.period, "0900-0930", sessionTZ))
inNewYorkOR = not na(time(timeframe.period, "1530-1545", sessionTZ))
inSingleOR = not na(time(timeframe.period, isMultiSession ? "1530-1545" : singleSessionString, sessionTZ))

inSession = isMultiSession ? (inJapanOR or inLondonOR or inNewYorkOR) : inSingleOR

var float orHigh = na
var float orLow  = na
var int   orBarCount = 0
var box   orBox = na
var bool  breakoutDoneToday = false
// Gestion par session : après une perte, on se redonne une deuxième (et
// dernière) chance sur le même OR ; après un gain, on arrête cette session.
var int   sessionTradeCount = 0
var bool  sessionWinLock    = false
// Sens autorisé pour le range en cours, figé à l'ouverture de la session
// (les fenêtres Japon/Londres/NY ne se chevauchent jamais).
var bool  orLongsAllowed    = true
// TP du trade en cours (pour la sortie anticipée par proximité de clôture,
// et pour le TP dynamique qui le rapproche au fil des nouveaux swings).
var float activeTpPrice     = na
// SL du trade en cours, figé à l'entrée — nécessaire pour réémettre
// strategy.exit quand le TP dynamique bouge (les deux valeurs doivent être
// repassées à chaque appel, sinon l'omise est annulée).
var float activeSlPrice     = na
// Barre et prix d'entrée du trade en cours : le TP dynamique n'accepte que
// des swings formés strictement APRÈS cette barre, au-delà de ce prix dans le
// sens du trade (cas GC du 18 juin 02:55 sur la variante Asia London : le TP
// sautait sur un micro-pivot qui venait de se faire, parfois SOUS l'entrée,
// et « TP proximité swing » fermait le trade 2 bougies plus tard à ~2 points,
// au lieu de viser le swing récent établi — ex. swing haut du 17 juin 20h45).
var int   entryBarIdx       = na
var float entryPxSaved      = na

// "na(orHigh)" couvre le cas limite où la toute première barre chargée à
// l'écran tombe déjà dans une session (inSession[1] vaut alors na, pas false).
isNewSessionStart = inSession and (not inSession[1] or na(orHigh))

if inSession
    if isNewSessionStart
        orHigh := high
        orLow := low
        orBarCount := 1
        // Réinitialisé ici (au DÉBUT de chaque nouvelle session), pas seulement au
        // changement de jour calendaire — sinon un range déjà "consommé" pouvait
        // redevenir éligible après minuit si la fenêtre de recherche (maxSessionHours)
        // chevauchait le changement de jour (même bug que celui déjà corrigé, mais
        // côté "attempt flag" plutôt que côté "fenêtre temporelle").
        breakoutDoneToday := false
        sessionTradeCount := 0
        sessionWinLock := false
        orLongsAllowed := not (disableLongsJapanLondon and (inJapanOR or inLondonOR))
        // Nouvelle boîte visuelle, mise à jour en direct à chaque barre de la
        // session (mèche haute/basse incluse) — on voit l'OR se former en temps réel.
        orBox := box.new(bar_index, high, bar_index, low, border_color=color.new(color.blue, 40),
             bgcolor=color.new(color.blue, 90))
    else
        orHigh := math.max(orHigh, high)
        orLow := math.min(orLow, low)
        orBarCount += 1
        box.set_top(orBox, orHigh)
        box.set_bottom(orBox, orLow)
        box.set_right(orBox, bar_index)

sessionJustEnded = not inSession and inSession[1]

var float orMid = na
var bool  orLocked = false
var int   sessionEndTime = na

if sessionJustEnded
    orMid := (orHigh + orLow) / 2
    orLocked := true
    sessionEndTime := time

// Fenêtre de validité du breakout : au-delà de maxSessionHours après la clôture
// de l'OR, on arrête de chercher un trade sur ce range (il devient trop "vieux").
withinTradingWindow = not na(sessionEndTime) and (time - sessionEndTime) <= maxSessionHours * 60 * 60 * 1000

// ============================================================================
// 2) H/L DE LA SESSION PRÉCÉDENTE (proxy : veille, journalier)
// ============================================================================
prevDayHigh = request.security(syminfo.tickerid, "1D", high[1], lookahead=barmerge.lookahead_off)
prevDayLow  = request.security(syminfo.tickerid, "1D", low[1],  lookahead=barmerge.lookahead_off)

// ============================================================================
// 3) SWINGS (PIVOTS) — recherche du swing le plus proche au-delà d'un niveau
// ============================================================================
pivotHighVal = ta.pivothigh(high, pivotLen, pivotLen)
pivotLowVal  = ta.pivotlow(low, pivotLen, pivotLen)

var array<float> pivotHighs     = array.new_float()
var array<int>   pivotHighBars  = array.new_int()
var array<float> pivotLows      = array.new_float()
var array<int>   pivotLowBars   = array.new_int()

if not na(pivotHighVal)
    array.push(pivotHighs, pivotHighVal)
    array.push(pivotHighBars, bar_index - pivotLen)
if not na(pivotLowVal)
    array.push(pivotLows, pivotLowVal)
    array.push(pivotLowBars, bar_index - pivotLen)

while array.size(pivotHighBars) > 0 and bar_index - array.get(pivotHighBars, 0) > pivotLookback
    array.shift(pivotHighs)
    array.shift(pivotHighBars)
while array.size(pivotLowBars) > 0 and bar_index - array.get(pivotLowBars, 0) > pivotLookback
    array.shift(pivotLows)
    array.shift(pivotLowBars)

// minFormBar (na = pas de restriction) : seuls les pivots dont la bougie de
// FORMATION est strictement postérieure à cette barre sont retenus — utilisé
// par le TP dynamique avec la barre d'entrée, car un swing qui existait déjà
// avant l'entrée (ou formé sur la bougie d'entrée elle-même) est du bruit du
// mouvement en cours, pas de la liquidité cible.
nearestSwingAbove(level, minFormBar) =>
    float nearest = na
    if array.size(pivotHighs) > 0
        for i = 0 to array.size(pivotHighs) - 1
            p = array.get(pivotHighs, i)
            fb = array.get(pivotHighBars, i)
            if p > level and (na(minFormBar) or fb > minFormBar) and (na(nearest) or p < nearest)
                nearest := p
    nearest

nearestSwingBelow(level, minFormBar) =>
    float nearest = na
    if array.size(pivotLows) > 0
        for i = 0 to array.size(pivotLows) - 1
            p = array.get(pivotLows, i)
            fb = array.get(pivotLowBars, i)
            if p < level and (na(minFormBar) or fb > minFormBar) and (na(nearest) or p > nearest)
                nearest := p
    nearest

// ============================================================================
// 4) COMPTEURS JOURNALIERS (2 pertes max / stop après 1 gain)
// ============================================================================
var int  dayLosses = 0
var int  dayWins = 0

newTradingDay = ta.change(time("D")) != 0
if newTradingDay
    dayLosses := 0
    dayWins := 0
    breakoutDoneToday := false

var int lastClosedCount = 0
if strategy.closedtrades > lastClosedCount
    tradeProfit = strategy.closedtrades.profit(strategy.closedtrades - 1)
    if tradeProfit > 0
        dayWins += 1
        // Gagnant : on arrête de chercher un nouveau trade sur cette session.
        sessionWinLock := true
    else
        dayLosses += 1
        // Perdant : deuxième (et dernière) chance sur cette session — on
        // rouvre la recherche de breakout tant que sessionTradeCount < 2.
        if sessionTradeCount < 2
            breakoutDoneToday := false
    lastClosedCount := strategy.closedtrades

canTradeToday = dayLosses < maxLossesDay and (not stopAfterWin or dayWins < 1)

// ============================================================================
// 5) FLATTEN DE FIN DE JOURNÉE
// ============================================================================
eodFlatten = useEodFlatten and (hour == flattenHour and minute >= flattenMinute)
if eodFlatten
    // cancel_all AVANT close_all, impérativement : dans l'ordre inverse,
    // cancel_all annulait aussi l'ordre de fermeture que close_all venait de
    // soumettre sur la même barre — le flatten ne s'est donc JAMAIS exécuté
    // (positions tenues overnight, ex. long du 18 juin gardé 34h).
    strategy.cancel_all()
    if strategy.position_size != 0
        strategy.close_all(comment="Flatten fin de journée")

// ============================================================================
// 6) DÉTECTION DU BREAKOUT — clôture 5m qui CASSE l'opening range
//    Le signal est le franchissement (clôture précédente dans le range,
//    clôture courante dehors), pas le simple fait d'être hors du range :
//    sinon, quand la bougie de cassure est refusée (R:R, filtre slide 5),
//    le code réévaluait chaque bougie suivante et finissait par entrer
//    40-70 min plus tard, loin du niveau, en plein milieu du mouvement.
//    Après un refus, il faut que le prix réintègre le range et re-casse
//    pour générer un nouveau signal.
// ============================================================================
firstBreakoutCheck = not inSession and orLocked and not breakoutDoneToday and not sessionWinLock and canTradeToday and not eodFlatten and withinTradingWindow
crossedAboveOR = close > orHigh and close[1] <= orHigh
crossedBelowOR = close < orLow  and close[1] >= orLow
longBreakout  = firstBreakoutCheck and crossedAboveOR and orLongsAllowed
shortBreakout = firstBreakoutCheck and crossedBelowOR

atrVal = ta.atr(atrLen)
minDist = proximityMult * atrVal

// Swing le plus proche au-delà du niveau, connu AU MOMENT de la bougie de
// cassure — inclut donc les swings confirmés entre la clôture de l'OR et
// l'entrée (ex. un swing low formé à 16h30 pour une cassure à 17h40), qui
// sont souvent la cible la plus logique et la plus proche. Les entrées
// tardives sont déjà empêchées par la règle de cassure franche (section 6),
// donc plus besoin de figer cette valeur à la clôture de l'OR.
nearestHighAbove = nearestSwingAbove(orHigh, int(na))
nearestLowBelow  = nearestSwingBelow(orLow, int(na))

// Filtre 1 : le niveau cassé est-il collé au H/L de la session précédente ?
tooCloseToPrevHigh = usePrevSessionFilter and not na(prevDayHigh) and math.abs(orHigh - prevDayHigh) <= minDist
tooCloseToPrevLow  = usePrevSessionFilter and not na(prevDayLow)  and math.abs(orLow  - prevDayLow)  <= minDist

// Filtre 2 : y a-t-il de la vraie liquidité (swing) au-delà pour continuer ?
hasLiquidityAbove = useSwingFilter ? (not na(nearestHighAbove) and (nearestHighAbove - orHigh) > minDist) : true
hasLiquidityBelow = useSwingFilter ? (not na(nearestLowBelow)  and (orLow - nearestLowBelow)  > minDist) : true

// Invalidation (slide 5) : trop proche du H/L précédent ET pas de liquidité au-delà
longInvalid  = tooCloseToPrevHigh and not hasLiquidityAbove
shortInvalid = tooCloseToPrevLow  and not hasLiquidityBelow

// ============================================================================
// 7) ENTRÉE — marché uniquement, sur cassure du CORPS de la bougie (close),
//    pas de retest : si le R:R est insuffisant, aucun trade n'est pris.
//    TP = swing (liquidité) le plus proche au-delà du niveau cassé, tel que
//    connu à la bougie de cassure — pas une projection géométrique arbitraire.
//    Si aucun swing n'existe au-delà à ce moment-là, il n'y a pas de cible de
//    structure valable donc pas de trade.
//    IMPORTANT : breakoutDoneToday ne se verrouille QUE quand un trade est
//    réellement entré — une clôture hors range invalidée (slide 5) ou dont le
//    R:R est insuffisant ne doit pas bloquer les clôtures suivantes de la même
//    session (sinon un seul signal filtré condamne toute la fenêtre de trading,
//    même si une meilleure structure apparaît juste après).
// ============================================================================
if longBreakout and not longInvalid and not na(nearestHighAbove)
    entryPrice = close
    slPrice = orMid
    tpPrice = nearestHighAbove
    riskPts = entryPrice - slPrice
    rewardPts = tpPrice - entryPrice
    rr = riskPts > 0 ? rewardPts / riskPts : na

    if riskPts > 0 and rr >= minRR
        strategy.entry("Long Marché", strategy.long, comment="ORB Long Marché")
        strategy.exit("Sortie Long", from_entry="Long Marché", stop=slPrice, limit=tpPrice)
        breakoutDoneToday := true
        sessionTradeCount += 1
        activeTpPrice := tpPrice
        activeSlPrice := slPrice
        entryBarIdx := bar_index
        entryPxSaved := entryPrice
        alert("ORB LONG (marché) @ " + str.tostring(entryPrice, format.mintick) +
              " | SL " + str.tostring(slPrice, format.mintick) +
              " | TP (swing) " + str.tostring(tpPrice, format.mintick), alert.freq_once_per_bar_close)

if shortBreakout and not shortInvalid and not na(nearestLowBelow)
    entryPrice = close
    slPrice = orMid
    tpPrice = nearestLowBelow
    riskPts = slPrice - entryPrice
    rewardPts = entryPrice - tpPrice
    rr = riskPts > 0 ? rewardPts / riskPts : na

    if riskPts > 0 and rr >= minRR
        strategy.entry("Short Marché", strategy.short, comment="ORB Short Marché")
        strategy.exit("Sortie Short", from_entry="Short Marché", stop=slPrice, limit=tpPrice)
        breakoutDoneToday := true
        sessionTradeCount += 1
        activeTpPrice := tpPrice
        activeSlPrice := slPrice
        entryBarIdx := bar_index
        entryPxSaved := entryPrice
        alert("ORB SHORT (marché) @ " + str.tostring(entryPrice, format.mintick) +
              " | SL " + str.tostring(slPrice, format.mintick) +
              " | TP (swing) " + str.tostring(tpPrice, format.mintick), alert.freq_once_per_bar_close)

// ============================================================================
// 7bis) TP DYNAMIQUE — au lieu de garder le swing connu à l'entrée (qui peut
//    être lointain et faire courir le trade des heures, jusque dans la
//    session suivante), on suit les swings qui se forment pendant le trade.
//    Garde-fous (cas GC du 18 juin 02:55 sur la variante Asia London) : seuls
//    comptent les pivots formés strictement APRÈS la bougie d'entrée, au-delà
//    du prix d'entrée d'au moins minDist (x ATR) dans le sens du trade — un
//    micro-swing qui vient de se faire au niveau de l'entrée n'est pas une
//    cible, le TP initial reste le swing récent établi. Le TP ne peut que se
//    rapprocher (jamais s'éloigner). Le stop (activeSlPrice, figé à l'entrée)
//    est toujours repassé tel quel : strategy.exit() annule tout paramètre
//    non fourni au réappel.
// ============================================================================
if dynamicTpFollow and strategy.position_size != 0 and not na(activeTpPrice) and not na(entryBarIdx)
    if strategy.position_size > 0
        // Long : swing haut formé après l'entrée, au-dessus d'entrée + minDist,
        // plus proche que le TP courant
        candidateTp = nearestSwingAbove(math.max(entryPxSaved + minDist, orHigh), entryBarIdx)
        if not na(candidateTp) and candidateTp < activeTpPrice
            activeTpPrice := candidateTp
            strategy.exit("Sortie Long", from_entry="Long Marché", stop=activeSlPrice, limit=activeTpPrice)
    else
        // Short : swing bas formé après l'entrée, sous entrée - minDist,
        // plus proche que le TP courant
        candidateTp = nearestSwingBelow(math.min(entryPxSaved - minDist, orLow), entryBarIdx)
        if not na(candidateTp) and candidateTp > activeTpPrice
            activeTpPrice := candidateTp
            strategy.exit("Sortie Short", from_entry="Short Marché", stop=activeSlPrice, limit=activeTpPrice)

// ============================================================================
// 8) SORTIE ANTICIPÉE — clôture de bougie à moins de X ticks du swing cible :
//    on prend le profit sur la clôture au lieu d'exiger que la limite soit
//    touchée au tick près (le marché s'arrête souvent juste sous/sur la
//    liquidité du swing avant de se retourner).
// ============================================================================
tpTolerance = tpProximityTicks * syminfo.mintick
longNearTp  = tpProximityTicks > 0 and strategy.position_size > 0 and not na(activeTpPrice) and close >= activeTpPrice - tpTolerance
shortNearTp = tpProximityTicks > 0 and strategy.position_size < 0 and not na(activeTpPrice) and close <= activeTpPrice + tpTolerance
if longNearTp or shortNearTp
    strategy.cancel_all()
    strategy.close_all(comment="TP proximité swing")
    activeTpPrice := na
    activeSlPrice := na
    entryBarIdx := na
    entryPxSaved := na
if strategy.position_size == 0 and not (longBreakout or shortBreakout)
    activeTpPrice := na
    activeSlPrice := na
    entryBarIdx := na
    entryPxSaved := na

// ============================================================================
// VISUELS
// ============================================================================
bgcolor(inSession ? color.new(color.blue, 85) : na, title="Fenêtre Opening Range")

plot(orLocked ? orHigh : na, "OR High", color=color.new(color.teal, 0), style=plot.style_linebr, linewidth=1)
plot(orLocked ? orLow  : na, "OR Low",  color=color.new(color.red, 0),  style=plot.style_linebr, linewidth=1)
plot(orLocked ? orMid  : na, "OR Mid (SL)", color=color.new(color.gray, 40), style=plot.style_linebr, linewidth=1)

// Cible de structure (swing le plus proche au-delà du niveau cassé) = TP potentiel.
plot(orLocked ? nearestHighAbove : na, "TP Long (swing structure)", color=color.new(color.lime, 20), style=plot.style_linebr, linewidth=1)
plot(orLocked ? nearestLowBelow  : na, "TP Short (swing structure)", color=color.new(color.maroon, 20), style=plot.style_linebr, linewidth=1)

plot(prevDayHigh, "Prev Session High", color=color.new(color.orange, 60), style=plot.style_linebr, linewidth=1)
plot(prevDayLow,  "Prev Session Low",  color=color.new(color.orange, 60), style=plot.style_linebr, linewidth=1)

plotshape(not na(pivotHighVal), title="Swing High", style=shape.triangledown, location=location.abovebar,
     color=color.fuchsia, size=size.tiny, offset=-pivotLen)
plotshape(not na(pivotLowVal), title="Swing Low", style=shape.triangleup, location=location.belowbar,
     color=color.fuchsia, size=size.tiny, offset=-pivotLen)

if longBreakout and longInvalid
    label.new(bar_index, high, "ORB Long invalidé\n(proche prev high, pas de liquidité)",
         style=label.style_label_down, color=color.new(color.orange, 20), textcolor=color.white, size=size.small)
if shortBreakout and shortInvalid
    label.new(bar_index, low, "ORB Short invalidé\n(proche prev low, pas de liquidité)",
         style=label.style_label_up, color=color.new(color.orange, 20), textcolor=color.white, size=size.small)
