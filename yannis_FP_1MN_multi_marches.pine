//@version=6
strategy("FP Multi-Marchés 1mn", pyramiding = 0, overlay = true, margin_long = 5, margin_short = 5, max_lines_count = 500, max_labels_count = 500, slippage=2)

// ═══════════════════════════════════════════════════════════════════════════
// FP Multi-Marchés — adaptation du script FP 1MN (NQ) aux futures GC, SI, CL,
// NG et FDAX. Les heures de sessions (heure de Paris) et l'échelle des stops
// (points) sont préréglées par marché ; les news hebdomadaires EIA (CL :
// stocks pétrole mercredi 16h30, NG : stocks gaz jeudi 16h30) créent une
// bougie de référence fair price dédiée, comme les news 14h30/20h00.
// Synchronisé le 10/07 : nuit/Asie OFF sur CL et NG + clôture au profit fixe.
// ═══════════════════════════════════════════════════════════════════════════

// ─── Marché : préréglage sessions + échelle de stops ─────────────────────────
marche = input.string('Auto (symbole)', 'Marché', options=['Auto (symbole)', 'NQ / indices US', 'GC (or)', 'SI (argent)', 'CL (pétrole WTI)', 'NG (gaz naturel)', 'FDAX (DAX)', 'Personnalisé'], group='Marché')
qtyIn  = input.int(10, 'Contrats par trade', minval=1, group='Marché')

// Mode Personnalisé : sessions en heure de Paris. La bougie de référence est
// la bougie 1 mn qui OUVRE à l'heure indiquée — le biais (refBull/refBear)
// est figé à sa clôture, 1 minute plus tard. Session principale US : la
// minute AVANT l'ouverture (15:29 → biais figé à 15:30, l'open cash) ;
// Asie/Londres : la première bougie de la session (02:00 → biais à 02:01,
// 09:00 → biais à 09:01) — réglage utilisateur du 13/07.
pSAon = input.bool(true, '', group='Marché — Personnalisé', inline='pA')
pSAH = input.int(15, 'Session principale  h', minval=0, maxval=23, group='Marché — Personnalisé', inline='pA')
pSAM = input.int(29, 'min', minval=0, maxval=59, group='Marché — Personnalisé', inline='pA')
pSBon = input.bool(true, '', group='Marché — Personnalisé', inline='pB')
pSBH = input.int(0,  'Réouverture nuit    h', minval=0, maxval=23, group='Marché — Personnalisé', inline='pB')
pSBM = input.int(0,  'min', minval=0, maxval=59, group='Marché — Personnalisé', inline='pB')
pSCon = input.bool(true, '', group='Marché — Personnalisé', inline='pC')
pSCH = input.int(2,  'Session asiatique   h', minval=0, maxval=23, group='Marché — Personnalisé', inline='pC')
pSCM = input.int(0,  'min', minval=0, maxval=59, group='Marché — Personnalisé', inline='pC')
pSDon = input.bool(true, '', group='Marché — Personnalisé', inline='pD')
pSDH = input.int(9,  'Session Londres     h', minval=0, maxval=23, group='Marché — Personnalisé', inline='pD')
pSDM = input.int(0,  'min', minval=0, maxval=59, group='Marché — Personnalisé', inline='pD')
pHebOn  = input.bool(false, 'News hebdo récurrente', group='Marché — Personnalisé', inline='pH')
pHebDay = input.string('Mercredi', '', options=['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi'], group='Marché — Personnalisé', inline='pH')
pHebH = input.int(16, 'News hebdo          h', minval=0, maxval=23, group='Marché — Personnalisé', inline='pH2')
pHebM = input.int(29, 'min', minval=0, maxval=59, group='Marché — Personnalisé', inline='pH2')
pK = input.float(1.0, 'Échelle volatilité vs NQ (k)', minval=0.000001, step=0.05, group='Marché — Personnalisé')

// ─── Webhook : alertes JSON vers le dispatcher FastAPI (state_manager) ───────
// Le serveur choisit le compte (rotation 1 trade/compte/jour) et la taille
// réelle ; qty est indicatif. Créer UNE alerte TradingView sur la stratégie
// avec la condition « Toute fonction alert() » et l'URL du webhook.
useWebhook    = input.bool(false, 'Alertes webhook JSON', group='Webhook')
whSecret      = input.string('CHANGE_ME', 'Secret partagé', group='Webhook', tooltip='Doit correspondre au secret attendu par le serveur FastAPI')
whStrat       = input.string('FP_MULTI_1MN', 'Identifiant stratégie', group='Webhook')
whSendUpdates = input.bool(false, 'Envoyer les màj de stop (trailing)', group='Webhook', tooltip='Envoie modify_stop quand le stop suiveur bouge (types cross / break-even). Max 1 alerte par bougie.')

pHebDow = switch pHebDay
    'Lundi'    => dayofweek.monday
    'Mardi'    => dayofweek.tuesday
    'Mercredi' => dayofweek.wednesday
    'Jeudi'    => dayofweek.thursday
    => dayofweek.friday

// Détection automatique par racine du symbole (GC1!, MCL1!, FDAX1!…)
rootSym = str.upper(syminfo.root == '' ? syminfo.ticker : syminfo.root)
mktEff = marche != 'Auto (symbole)' ? marche :
     rootSym == 'GC' or rootSym == 'MGC' ? 'GC (or)' :
     rootSym == 'SI' or rootSym == 'SIL' ? 'SI (argent)' :
     rootSym == 'CL' or rootSym == 'MCL' or rootSym == 'QM' ? 'CL (pétrole WTI)' :
     rootSym == 'NG' or rootSym == 'MNG' or rootSym == 'QG' ? 'NG (gaz naturel)' :
     str.contains(rootSym, 'DAX') ? 'FDAX (DAX)' : 'NQ / indices US'

// Sessions par marché (heure de Paris) — mêmes 4 slots que le script NQ :
// slot A = session principale (comportement « USA » : pas de cross, reset lastPeriod)
// slot B = réouverture nuit Globex/Eurex (bougie réf = première bougie de la session)
// slot C = session asiatique | slot D = Londres
// Bougie de référence = la bougie 1 mn qui OUVRE à l'heure du slot ; le biais
// (refBull/refBear) est figé à sa CLÔTURE, 1 minute plus tard. Règle 13/07 :
// A (US) = minute avant l'open cash (15h29 → biais à 15h30) ; C/D (Asie et
// Londres) = première bougie de la session (02h00 → biais à 02h01, 09h00 →
// biais à 09h01) — avant, C/D étaient à 01h59/08h59.
// NQ   : A 15h29 (cash US 15h30), B 00h00 (Globex), C 02h00, D 09h00
// GC/SI : A 14h19 (COMEX 14h20 = 8h20 ET), B 00h00, C 02h00, D 09h00
// CL/NG : A 14h59 (pit NYMEX 15h00 = 9h00 ET), B 00h00, C 02h00, D 09h00
// FDAX : A 08h59 (Xetra 09h00), B 01h10 (réouverture Eurex),
//        C 15h29 (cash US 15h30), D 17h29 (clôture Xetra 17h30)
[sAH, sAM, sBH, sBM, sCH, sCM, sDH, sDM] = switch mktEff
    'GC (or)'          => [14, 19, 0, 0, 2, 0, 9, 0]
    'SI (argent)'      => [14, 19, 0, 0, 2, 0, 9, 0]
    'CL (pétrole WTI)' => [14, 59, 0, 0, 2, 0, 9, 0]
    'NG (gaz naturel)' => [14, 59, 0, 0, 2, 0, 9, 0]
    'FDAX (DAX)'       => [8, 59, 1, 10, 15, 29, 17, 29]
    'Personnalisé'     => [pSAH, pSAM, pSBH, pSBM, pSCH, pSCM, pSDH, pSDM]
    => [15, 29, 0, 0, 2, 0, 9, 0]

// Activation des slots par marché : sur CL/NG, aucun trade entre 00h00 et
// 08h00 Paris (retour utilisateur 10/07) — slots nuit (B) et Asie (C) OFF,
// l'énergie n'a pas de volume exploitable avant Londres
[sAon, sBon, sCon, sDon] = switch mktEff
    'CL (pétrole WTI)' => [true, false, false, true]
    'NG (gaz naturel)' => [true, false, false, true]
    'Personnalisé'     => [pSAon, pSBon, pSCon, pSDon]
    => [true, true, true, true]

// News hebdomadaire récurrente (heure de Paris, bougie réf 1 min avant) :
// CL : stocks pétrole EIA, mercredi 16h30 (10h30 ET)
// NG : stocks gaz EIA, jeudi 16h30 (10h30 ET)
[hebOn, hebDow, hebH, hebM] = switch mktEff
    'CL (pétrole WTI)' => [true, dayofweek.wednesday, 16, 29]
    'NG (gaz naturel)' => [true, dayofweek.thursday, 16, 29]
    'Personnalisé'     => [pHebOn, pHebDow, pHebH, pHebM]
    => [false, dayofweek.wednesday, 16, 29]

// Échelle de volatilité vs NQ (k) : médiane du true range 1 mn mesurée sur
// 6 jours (03-09/07/2026), rapportée au NQ (11,75 pts). Tous les seuils en
// points du script NQ (paliers SL/TP, seuils ATR5 7/20, buffer FP 20 pts,
// stop structurel 2/10/50) sont multipliés par k : le comportement de base
// du NQ est reproduit à l'échelle de chaque marché.
// Médianes mesurées : GC 1,70 | SI 0,045 | CL 0,05 | NG 0,002 | FDAX 7,0
kMkt = switch mktEff
    'GC (or)'          => 0.15
    'SI (argent)'      => 0.004
    'CL (pétrole WTI)' => 0.0045
    'NG (gaz naturel)' => 0.00018
    'FDAX (DAX)'       => 0.6
    'Personnalisé'     => pK
    => 1.0


newsDays = input.string(
     "",
     "News 20h00 (ex: 1,5,12,30)",
     group="20h00"
)

// ─── Calendrier News 14h30 (jour du mois) ──────────────────────────────────────
news1430_01 = input.bool(false, "1",  group="14h30", inline="n1")
news1430_02 = input.bool(false, "2",  group="14h30", inline="n1")
news1430_03 = input.bool(false, "3",  group="14h30", inline="n1")
news1430_04 = input.bool(false, "4",  group="14h30", inline="n1")
news1430_05 = input.bool(false, "5",  group="14h30", inline="n1")
news1430_06 = input.bool(false, "6",  group="14h30", inline="n1")
news1430_07 = input.bool(false, "7",  group="14h30", inline="n1")
news1430_08 = input.bool(false, "8",  group="14h30", inline="n1")
news1430_09 = input.bool(false, "9",  group="14h30", inline="n1")
news1430_10 = input.bool(false, "10", group="14h30", inline="n1")
news1430_11 = input.bool(false, "11", group="14h30", inline="n2")
news1430_12 = input.bool(false, "12", group="14h30", inline="n2")
news1430_13 = input.bool(false, "13", group="14h30", inline="n2")
news1430_14 = input.bool(false, "14", group="14h30", inline="n2")
news1430_15 = input.bool(false, "15", group="14h30", inline="n2")
news1430_16 = input.bool(false, "16", group="14h30", inline="n2")
news1430_17 = input.bool(false, "17", group="14h30", inline="n2")
news1430_18 = input.bool(false, "18", group="14h30", inline="n2")
news1430_19 = input.bool(false, "19", group="14h30", inline="n2")
news1430_20 = input.bool(false, "20", group="14h30", inline="n2")
news1430_21 = input.bool(false, "21", group="14h30", inline="n3")
news1430_22 = input.bool(false, "22", group="14h30", inline="n3")
news1430_23 = input.bool(false, "23", group="14h30", inline="n3")
news1430_24 = input.bool(false, "24", group="14h30", inline="n3")
news1430_25 = input.bool(false, "25", group="14h30", inline="n3")
news1430_26 = input.bool(false, "26", group="14h30", inline="n3")
news1430_27 = input.bool(false, "27", group="14h30", inline="n3")
news1430_28 = input.bool(false, "28", group="14h30", inline="n3")
news1430_29 = input.bool(false, "29", group="14h30", inline="n3")
news1430_30 = input.bool(false, "30", group="14h30", inline="n3")
news1430_31 = input.bool(false, "31", group="14h30", inline="n4")




var line myLineClose = na
var line myLineOpen = na

var float currentPeriod = na
var float lastPeriod = na

var float openValue = na
var float closeValue = na

var float entry_price = na
var float stop_price = na
var float tp_price = na

var float minAtrUp = na
var float minAtrDown = na

// ─── Break-even à 1R (continuations) ─────────────────────────────────────────
var float beTarget = na
var bool  beArmed  = false

var bool muchSell = false
var bool muchBuy = false

var bool continuePeriod = true

var string tradeType = ""

var int maxCount = 100

max_bars_in_trade = 20

vol = volume[0]
avg = ta.sma(vol, 5)

var float[] structures = array.new_float()

hourCET   = hour(time, "Europe/Paris")
minuteCET = minute(time, "Europe/Paris")
dayCET = dayofmonth(time, "Europe/Paris")
dowCET = dayofweek(time, "Europe/Paris")

float tp = na
float sp = na

tick = syminfo.mintick
atr5 = ta.atr(5)

// ─── Bandes ATR (déplacées en tête : servent aussi au buffer FP et au stop) ──
length = 5
m = input(1.5, "Multiplier")
src1 = input(high)
src2 = input(low)
a = ta.rma(ta.tr(true), length) * m
x = ta.rma(ta.tr(true), length) * m + src1
x2 = src2 - ta.rma(ta.tr(true), length) * m

// Paliers SL/TP de base du NQ (16,5/25/50 -> 24,75/38,5/75, seuils ATR5 7/20)
// multipliés par l'échelle de volatilité k du marché
if atr5 >= 20 * kMkt
    sp := 50 * kMkt
    tp := 75 * kMkt
else if atr5 < 7 * kMkt
    sp := 16.5 * kMkt
    tp := 24.75 * kMkt
else
    sp := 25 * kMkt
    tp := 38.5 * kMkt

bodyHigh = math.max(open, close)
bodyLow = math.min(open, close)

candleBuy = close > open
candleSell = open > close




isNews2000Today = str.contains("," + newsDays + ",", "," + str.tostring(dayCET) + ",")



isNews1430Today =
     (dayCET == 1 and news1430_01) or
     (dayCET == 2 and news1430_02) or
     (dayCET == 3 and news1430_03) or
     (dayCET == 4 and news1430_04) or
     (dayCET == 5 and news1430_05) or
     (dayCET == 6 and news1430_06) or
     (dayCET == 7 and news1430_07) or
     (dayCET == 8 and news1430_08) or
     (dayCET == 9 and news1430_09) or
     (dayCET == 10 and news1430_10) or
     (dayCET == 11 and news1430_11) or
     (dayCET == 12 and news1430_12) or
     (dayCET == 13 and news1430_13) or
     (dayCET == 14 and news1430_14) or
     (dayCET == 15 and news1430_15) or
     (dayCET == 16 and news1430_16) or
     (dayCET == 17 and news1430_17) or
     (dayCET == 18 and news1430_18) or
     (dayCET == 19 and news1430_19) or
     (dayCET == 20 and news1430_20) or
     (dayCET == 21 and news1430_21) or
     (dayCET == 22 and news1430_22) or
     (dayCET == 23 and news1430_23) or
     (dayCET == 24 and news1430_24) or
     (dayCET == 25 and news1430_25) or
     (dayCET == 26 and news1430_26) or
     (dayCET == 27 and news1430_27) or
     (dayCET == 28 and news1430_28) or
     (dayCET == 29 and news1430_29) or
     (dayCET == 30 and news1430_30) or
     (dayCET == 31 and news1430_31)



// Fonction pour convertir HH:MM en minutes depuis minuit
toMinutes(h, m) =>
    h * 60 + m

// Fonction pour vérifier si on est dans une plage
inRange(startMin, offsetStart, offsetEnd) =>
    current = hourCET * 60 + minuteCET
    sessionStart = startMin + offsetStart
    sessionEnd = startMin + offsetEnd

    // gestion passage minuit
    if sessionEnd >= 1440
        current >= sessionStart or current <= sessionEnd - 1440
    else if sessionStart < 0
        current <= sessionEnd or current >= sessionStart + 1440
    else
        current >= sessionStart and current <= sessionEnd


// ======================
// SEULEMENT LES STARTS
// ======================

// Slots génériques pilotés par le préréglage marché (voir tableau en tête) :
// startUSA = slot A (principale), startMidnight = slot B (réouverture nuit),
// startJapan = slot C (Asie), startLondon = slot D (Londres)
startUSA      = sAon ? toMinutes(sAH, sAM) : na
startMidnight = sBon ? toMinutes(sBH, sBM) : na
startJapan    = sCon ? toMinutes(sCH, sCM) : na
startLondon   = sDon ? toMinutes(sDH, sDM) : na

startNews1430 = isNews1430Today ? toMinutes(14, 29) : na
startNews2000 = isNews2000Today ? toMinutes(19, 59) : na
startNewsHebdo = hebOn and dowCET == hebDow ? toMinutes(hebH, hebM) : na

// ======================
// CONDITIONS AUTO
// ======================

conditionStart =
     (not na(startUSA) and inRange(startUSA, 0, 0)) or
     (not na(startMidnight) and inRange(startMidnight, 0, 0)) or
     (not na(startJapan) and inRange(startJapan, 0, 0)) or
     (not na(startLondon) and inRange(startLondon, 0, 0)) or
     (not na(startNews1430) and inRange(startNews1430, 0, 0)) or
     (not na(startNews2000) and inRange(startNews2000, 0, 0)) or
     (not na(startNewsHebdo) and inRange(startNewsHebdo, 0, 0))



tradeTimeUSA = not na(startUSA) and inRange(startUSA, 1, 90)
tradeTimeMidnight = not na(startMidnight) and inRange(startMidnight, 0, 89)
tradeTimeJapan = not na(startJapan) and inRange(startJapan, 1, 90)
tradeTimeLondon = not na(startLondon) and inRange(startLondon, 1, 90)
tradeTimeNews1430 = (not na(startNews1430) and inRange(startNews1430, 1, 60))
tradeTimeNews2000 = (not na(startNews2000) and inRange(startNews2000, 1, 90))
tradeTimeNewsHebdo = (not na(startNewsHebdo) and inRange(startNewsHebdo, 1, 60))

tradeTime =
     tradeTimeUSA
     or
     tradeTimeMidnight
     or
     tradeTimeJapan
     or
     tradeTimeLondon
     or
     tradeTimeNews1430
     or
     tradeTimeNews2000
     or
     tradeTimeNewsHebdo

swingTimeUSA = not na(startUSA) and inRange(startUSA, -59, 90)
swingTimeMidnight = not na(startMidnight) and inRange(startMidnight, -60, 89)
swingTimeJapan = not na(startJapan) and inRange(startJapan, -59, 90)
swingTimeLondon = not na(startLondon) and inRange(startLondon, -59, 90)
swingTimeNews1430 = (not na(startNews1430) and inRange(startNews1430, -59, 60))
swingTimeNews2000 = (not na(startNews2000) and inRange(startNews2000, -59, 90))
swingTimeNewsHebdo = (not na(startNewsHebdo) and inRange(startNewsHebdo, -59, 60))

swingTime =
     swingTimeUSA
     or
     swingTimeMidnight
     or
     swingTimeJapan
     or
     swingTimeLondon
     or
     swingTimeNews1430
     or
     swingTimeNews2000
     or
     swingTimeNewsHebdo



if strategy.position_size == 0
    entry_price := na
    stop_price := na
    tp_price := na
    minAtrUp:= na
    minAtrDown := na
    beTarget := na
    beArmed := false

// ─── Re-entrée après perte : libère la fenêtre continuation pour un nouveau BOS ───
if strategy.position_size == 0 and strategy.position_size[1] != 0
    nClosed = strategy.closedtrades
    if nClosed > 0
        if strategy.closedtrades.profit(nClosed - 1) < 0
            continuePeriod := true


if conditionStart
    openValue := open
    closeValue := close

    structures := array.new_float()

    trend30m = (close - close[30]) / close[30] * 100

    muchSell := false
    muchBuy := false

    continuePeriod := true


    muchSell := trend30m < -0.2
    muchBuy := trend30m > 0.2


    if tradeTimeUSA
        lastPeriod := na

    if tradeTimeMidnight
        lastPeriod := currentPeriod

    else if tradeTimeJapan
        lastPeriod := currentPeriod

    else if tradeTimeLondon
        lastPeriod := currentPeriod

    currentPeriod := openValue


zoneHigh = math.max(openValue, closeValue)
zoneLow = math.min(openValue, closeValue)

// ─── Sens de la bougie de référence (open de session) ────────────────────────
refBull = closeValue > openValue
refBear = openValue > closeValue

// Buffer de proximité de la zone FP : 20 points NQ mis à l'échelle du marché
buffer = 20 * kMkt

longTime = tradeTime and high < closeValue
shortTime = tradeTime and low > closeValue

bodySize = math.abs(bodyHigh - bodyLow)

var float pushWickSize = na
var float highWickSize = na
var float lowWickSize = na

highWickSize := high - bodyHigh
lowWickSize := bodyLow - low

if longTime
    pushWickSize := highWickSize
if shortTime
    pushWickSize := lowWickSize

tooMuchWick = pushWickSize > bodySize * 0.4

tooCloseOfMean = bodyHigh >= zoneLow - buffer and bodyLow <= zoneHigh + buffer

canTrade = not tooCloseOfMean

volCond = volume > avg

lastStart = ta.barssince(conditionStart)


// 3. Volatilité - éviter les marchés calmes/ranging
// (atrFilter est défini plus bas, section TJR : mode sélectionnable)
atr14 = ta.atr(14)
trNow = ta.tr(true)


// (calculs a/x/x2 déplacés en tête de script, seuls les plots restent ici)
pline = input(true, "Show Price Lines")
col1 = input(color.blue, "ATR Text Color")
col2 = input(color.teal, "Low Text Color",inline ="1")
col3 = input(color.red, "High Text Color",inline ="2")

collong = input(color.teal, "Low Line Color",inline ="1")
colshort = input(color.red, "High Line Color",inline ="2")

p1 = plot(x, title = "ATR Short Stop Loss", color= colshort, trackprice = pline ? true : false)
p2 = plot(x2, title = "ATR Long Stop Loss", color= collong, trackprice = pline ? true : false)


// Inputs
swingSizeR1       = input.int(3, 'Rejection Swing ', inline='brl')
swingSizeL1       = input.int(3, '-', inline='brl')
swingSizeR2       = input.int(6, 'Continuation Swing ', inline='brl')
swingSizeL2       = input.int(6, '-', inline='brl')
showBoxes        = false
showSwingLines   = true
showBubbles      = true
showVol          = false
extendtilfilled  = true

// ─── TJR : confirmation structurelle + setup armé ───────────────────────────
// Filtres BOS activés par défaut (20/07, demande utilisateur) : le trade long
// du 13/07 01h11 (réversion nuit Globex) est entré sans aucune cassure de
// structure réelle — seul un retest de pivot mineur (anyFill) + micro-cassure
// locale (close > high[1]) l'armaient, structBias n'étant pas exigé tant que
// ce filtre restait désactivé (choix du 07/07, échantillon jugé trop court à
// l'époque). Ré-activé : exige désormais structBias == 1/-1 (clôture au-delà
// du dernier pivot série 2) avant toute entrée long/short, continuation comme
// réversion. A/B 13-20/07 NQ1! (qty 1) : sans filtre −1 455 $ / PF 0,89 / 39
// trades / DD 4 975 → avec filtre +405 $ / PF 1,18 / 10 trades / DD 1 780 (les
// 29 trades retirés sont presque tous des longs perdants).
useStructFilterLong  = input.bool(true, 'Filtre BOS structurel — Longs', group='TJR')
useStructFilterShort = input.bool(true, 'Filtre BOS structurel — Shorts', group='TJR')
armBars              = input.int(5, 'Validité setup armé (bougies, 0 = comportement original)', minval=0, group='TJR')

// ─── Continuation : fenêtre + sens de la bougie de référence ─────────────────
// Défaut 10 min : A/B du 07/07 — fenêtre 10 retire le plus gros short perdant
// (+128 800 $/PF 2,59 vs +118 700/2,30 en 15 min, gagnants identiques)
contWinMin = input.int(10, 'Fenêtre continuation (minutes)', minval=1, group='TJR')
useRefDir  = input.bool(true, 'Continuation : suivre le sens de la bougie de référence', group='TJR')

// ─── Corrections 07/07 (revue des trades perdants) ───────────────────────────
// 1. Réversion : le break d'une seule bougie après un fort déplacement est un
//    faux signal fréquent (ex. 22/06 16h01). Confirmation exigée :
//    'Engulfante' = le corps couvre le corps de la bougie précédente ;
//    'Cassure 2 bougies' = clôture au-delà des extrêmes des 2 dernières bougies
//    (variante assouplie qui rejette le break 1-bougie sans jeter le reste)
revConfirm   = input.string('Cassure 2 bougies', 'Réversion : confirmation requise', options=['Aucune', 'Engulfante', 'Cassure 2 bougies'], group='TJR')
// 2. Réversion : cible du take-profit —
//    'Bord proche zone FP' : premier contact de la zone (corrige le short 23/06
//    16h40 resté ouvert jusqu'à 20h40 sur le bord opposé) ;
//    'openValue (original)' : comportement historique ;
//    '1,5 ATR' : entrée ± 1,5 x ATR5 (sécurise vite, ne vise plus le FP)
revTP        = input.string('Bord proche zone FP', 'Réversion : take-profit', options=['Bord proche zone FP', 'openValue (original)', '1,5 ATR'], group='Gestion trade : BE / TP / ATR')
// 3. Continuation : break-even une fois 1R atteint (ex. long 24/06 02h08 :
//    +14 950 $ d'excursion favorable finie à -10 100 $)
useBE        = input.bool(true, 'Continuation : break-even à 1R', group='Gestion trade : BE / TP / ATR')
//    Étendu aux réversions le 08/07 : deux shorts USA (30/06 16h42 run-up
//    +20 600 $, 06/07 16h53 run-up +16 250 $) finis à -10 100 $ faute de BE
useBERev     = input.bool(true, 'Réversion : break-even à 1R', group='Gestion trade : BE / TP / ATR')
// 4. Filtre volatilité : l'expansion ATR(14) vs il y a 20 bougies est en retard
//    par construction (ex. 30/06 : signal 16h46 refusé, entrée décalée à 16h53
//    14 points plus bas). Défaut 'TR bougie > ATR' : valide l'expansion sur la
//    bougie signal même (A/B 28/06-08/07 : +75 300/PF 1,82 vs +36 850/1,63)
atrMode      = input.string('TR bougie > ATR', 'Filtre volatilité (ATR)', options=['Expansion 20 bougies', 'Expansion 10 bougies', 'TR bougie > ATR', 'Expansion 20 OU TR > ATR', 'Désactivé'], group='Gestion trade : BE / TP / ATR')
// 5. Clôture au profit fixe : sortie en limite dès que le gain latent du trade
//    atteint le montant choisi (en $ par trade, tous contrats confondus, hors
//    frais). Ne remplace le TP normal que s'il est plus proche que lui.
useProfitClose = input.bool(false, 'Clôture au profit fixe', group='Gestion trade : BE / TP / ATR')
profitCloseUsd = input.float(5000, 'Seuil de profit ($ par trade)', minval=100, step=100, group='Gestion trade : BE / TP / ATR')
atrFilter = switch atrMode
    'Expansion 20 bougies'     => atr14 > atr14[20]
    'Expansion 10 bougies'     => atr14 > atr14[10]
    'TR bougie > ATR'          => trNow > atr14
    'Expansion 20 OU TR > ATR' => atr14 > atr14[20] or trNow > atr14
    => true

// ─── TJR lot A/B/C : stop structurel + RR + re-entrées ───────────────────────
// useStructStop désactivé par défaut : sur le backtest 19/06→07/07 le stop ATR
// par paliers reste meilleur (PF 1,74 vs 1,66, DD 40 350 vs 45 350)
useStructStop    = input.bool(false, 'Stop structurel (au-delà du swing)', group='TJR')
stopLookback     = input.int(12, 'Lookback du stop (bougies)', minval=2, group='TJR')
// Buffer et bornes du stop structurel : valeurs NQ (2 / 10 / 50 points)
// mises à l'échelle de volatilité k du marché
structBuffer     = 2.0 * kMkt
minStopPts       = 10.0 * kMkt
maxStopPts       = 50.0 * kMkt
minRR            = input.float(1.0, 'RR minimum vers le fair price', minval=0, step=0.25, group='TJR')
maxEntriesWin    = input.int(3, 'Entrées max par fenêtre', minval=1, group='TJR')
reEnterAfterLoss = input.bool(true, 'Re-entrée après SL (thèse intacte)', group='TJR')
reArmBars        = input.int(20, 'Fenêtre re-entrée après SL (bougies)', minval=1, group='TJR')
liteReentry      = input.bool(true, 'Re-entrée allégée (bougie + cassure + FP)', group='TJR')
debugRearm       = input.bool(false, 'Debug re-entrées (table échecs filtres)', group='TJR')

// Conditions
hidefilled       = input.bool(false, 'Hide Filled', group='Conditions')
voltresh = input.int(0, 'Volume >', group='Conditions')

// Sortie « Fair price reached » : historiquement elle ferme TOUT trade dès
// qu'une bougie ouvre hors zone FP et clôture dedans. Pour une continuation,
// le retest de la zone juste après l'open est pourtant un comportement normal
// (cas du 15/07 02h06 : continuation asiatique coupée au retest avant de
// repartir dans le bon sens). Décoché : seules les réversions (dont le FP est
// la cible) sont fermées au fair price ; les continuations gardent leur
// SL/TP/break-even. Déclaré en dernier (indices in_N des graphiques).
useFpCloseCont = input.bool(true, 'Sortie fair price : fermer aussi les continuations', group='Gestion trade : BE / TP / ATR', tooltip='Coché = comportement historique (toute position est fermée quand une bougie clôture dans la zone FP). Décoché = les trades de continuation (continue / crossContinue) ne sont plus fermés au retour dans la zone fair price.')

// Fraîcheur du biais structurel (20/07). Sans reset, structBias est global et
// collant : il garde +1/-1 depuis la dernière cassure de pivot série 2, qui
// peut dater de plusieurs heures, et comme la condition est un test de niveau
// (close > lastHiStruct) réévalué à chaque bougie, il suffit que le prix soit encore
// au-dessus de l'ancien pivot. Coché : structBias ET les pivots mémorisés
// repartent de zéro à chaque bougie de référence, donc seule une cassure d'un
// pivot formé DANS la session peut valider structLongOk / structShortOk.
// Désactivé par défaut : A/B 13-20/07 NQ1! (qty 1) = −790 $ / PF 0,59 / 7 trades
// contre +405 $ / PF 1,18 / 10 trades sans reset. Et surtout le reset ne règle
// PAS le cas qui l'a motivé (long 13/07 01h11, toujours pris) : un pivot 6/6
// s'était formé et avait été cassé DANS la session Globex avant 01h11, donc la
// cassure est bien « fraîche » au sens du script. Le vrai écart est d'échelle —
// un pivot de 6 bougies en 1 mn est une microstructure, pas le BOS que l'œil
// lit sur le graphique. Déclaré en dernier : les indices in_N du graphique ne
// bougent pas.
structBiasReset = input.bool(false, 'BOS structurel : remettre à zéro à chaque session', group='TJR', tooltip='Coché = le biais structurel et les pivots mémorisés sont réinitialisés à chaque bougie de référence : seule une cassure survenue dans la session en cours peut valider structLongOk / structShortOk. Décoché (défaut) = comportement historique, biais collant hérité des sessions précédentes — meilleur en backtest (voir commentaire).')

// ─── Taille des pivots qui valident le BOS structurel (21/07) ────────────────
// structBias s'appuyait sur les pivots série 2 (« Continuation Swing », 6/6),
// partagés avec les niveaux dessinés : impossible de régler l'échelle du BOS
// sans changer aussi les niveaux. Cas du long NQ1! 21/07 16h18 — higher low,
// volume 2103 vs 1556 de moyenne, cassure du high de 16h14 (29 137,25), tous
// les autres filtres verts (RR compris : 57 pts vers le fair price pour un sp
// de 50) — refusé parce que le dernier pivot 6/6 confirmé était le sommet de
// 16h00 à 29 188,50, soit 36 points au-dessus de la clôture : structBias
// restait à -1 et structLongOk bloquait. Ces deux réglages découplent la
// taille du pivot qui valide le BOS de celle des niveaux dessinés, et la
// séparent longs (pivot high) / shorts (pivot low). Défaut 6 = comportement
// historique à l'identique ; 3 aurait pris le trade du 16h18 (pivot de 16h14
// confirmé à 16h17, cassé à la clôture de 16h18).
// Déclarés en dernier : les indices in_N du graphique ne bougent pas.
// 0 = hériter du « Continuation Swing » (swingSizeL2/R2), donc comportement
// v14 strictement reproduit QUELLE QUE SOIT la valeur de ce réglage — un
// défaut fixe à 6 aurait au contraire ignoré un Continuation Swing réglé à 3.
structPivLenLong  = input.int(0, 'BOS structurel — bougies du pivot (Longs)',  minval=0, group='TJR', tooltip='0 = suit le réglage Continuation Swing (comportement historique). Sinon : nombre de bougies à gauche ET à droite du pivot high dont la cassure en clôture valide la structure haussière (structLongOk). Plus petit = BOS plus réactif, proche de la microstructure lue sur le graphique ; plus grand = seuls les sommets majeurs comptent.')
structPivLenShort = input.int(0, 'BOS structurel — bougies du pivot (Shorts)', minval=0, group='TJR', tooltip='0 = suit le réglage Continuation Swing (comportement historique). Sinon : nombre de bougies à gauche ET à droite du pivot low dont la cassure en clôture valide la structure baissière (structShortOk).')

// ─── Source d'armement des réversions (21/07) ────────────────────────────────
// Asymétrie non voulue : les continuations ne s'arment que sur les fills de la
// série 2 (fillS2High / fillS2Low), conformément au nom « Continuation Swing »,
// alors que les réversions s'arment sur anyFill, qui mélange les deux séries.
// Le « Rejection Swing » ne pilote donc qu'une partie des armements de
// rejection, et le « Continuation Swing » en pilote l'autre — d'où l'effet
// constaté dans le dialogue de réglages. Aggravant : la série 1 n'est créée
// que pendant longTime/shortTime et d'un seul côté, la série 2 sans condition,
// donc c'est la série 2 qui domine anyFill.
// Défaut = comportement historique. À tester en A/B avant de changer : limiter
// à la série 1 réduira mécaniquement le nombre de réversions armées.
// Déclaré en dernier : les indices in_N du graphique ne bougent pas.
revArmSrc = input.string('Les deux (historique)', 'Réversion : niveaux qui arment le setup', options=['Les deux (historique)', 'Série 1 — Rejection Swing', 'Série 2 — Continuation Swing'], group='TJR', tooltip='Quels niveaux remplis (retest par le corps de la bougie) arment un setup de réversion. « Les deux » = comportement historique. « Série 1 » = seuls les pivots Rejection Swing comptent, ce qui rend le réglage Continuation Swing sans effet sur les rejections.')

// ── Évaluation prop firm : plafond de gain cumulé (distinct de la clôture au
// profit fixe, qui est un TP en $ PAR trade). Déclarés en DERNIER (indices
// in_N stables sur les graphiques existants).
grpEval = 'Évaluation prop firm'
evalAccount = input.bool(false, "Compte d'évaluation (plafonner le gain cumulé)", group=grpEval, tooltip="À cocher UNIQUEMENT pour un compte d'évaluation prop firm. Dès que le profit net cumulé atteint le plafond ci-dessous, la position est fermée (flatten de CE compte) et plus aucune nouvelle entrée n'est prise — l'objectif d'éval est sécurisé, verrouillage définitif. Les autres comptes continuent de trader indépendamment. Décoché pour un compte financé (aucun effet).")
maxGainEval = input.float(1500, 'Plafond de gain cumulé ($)', minval=0, step=50, group=grpEval, tooltip="Profit net cumulé (strategy.netprofit) à partir duquel on arrête ce compte. 1500 $ par défaut. Sans effet si « Compte d'évaluation » est décoché.")

// Appearance inputs
showhighs        = true
showlows         = true
sellcol          = #aa2430
buycol           = #66bb6a
sellcolB         = #aa2430
buycolB          = #66bb6a
sellboxCol       = #80192231
buyboxCol        = #66bb6a31
lineStyle        = 'Dotted'
lineWid          = 1
boxWid           = 0.7
boxStyle         = 'TYPE 1'
labelsize        = 'Size: Tiny'
texthalign       = 'Right'
lookback         = false

inRange          = true

// ─── Fix #4 : réinitialisation propre à chaque bougie ───────────────────────
pivHi1 = ta.pivothigh(high, swingSizeL1, swingSizeR1)
pivLo1 = ta.pivotlow (low,  swingSizeL1, swingSizeR1)
pivHi2 = ta.pivothigh(high, swingSizeL2, swingSizeR2)
pivLo2 = ta.pivotlow (low,  swingSizeL2, swingSizeR2)

// Fix #4 : flags toujours recalculés, jamais bloqués sur true
bool h1 = not na(pivHi1)
bool l1 = not na(pivLo1)
bool h2 = not na(pivHi2)
bool l2 = not na(pivLo2)

var int prevHighIndex1 = na
var int prevLowIndex1  = na
var int prevHighIndex2 = na
var int prevLowIndex2  = na

if h1
    prevHighIndex1 := bar_index - swingSizeR1
if l1
    prevLowIndex1  := bar_index - swingSizeR1
if h2
    prevHighIndex2 := bar_index - swingSizeR2
if l2
    prevLowIndex2  := bar_index - swingSizeR2

// ─── TJR Fix D : biais structurel — BOS confirmé en clôture ─────────────────
// +1 : dernier swing high cassé en clôture (structure haussière confirmée)
// -1 : dernier swing low cassé en clôture (structure baissière confirmée)
// Depuis le 21/07, les pivots de référence ont leur propre taille réglable
// (structPivLenLong / structPivLenShort) au lieu des pivots série 2 utilisés
// pour les niveaux dessinés — voir le commentaire des inputs.
// Les pivots dédiés sont calculés inconditionnellement (les ta.* ne doivent pas
// être appelées dans une branche conditionnelle), puis retenus seulement si le
// réglage est non nul ; sinon on réutilise les pivots série 2, qui conservent
// leurs tailles gauche/droite distinctes (swingSizeL2 ≠ swingSizeR2 possible).
pivHiDedie  = ta.pivothigh(high, math.max(structPivLenLong,  1), math.max(structPivLenLong,  1))
pivLoDedie  = ta.pivotlow (low,  math.max(structPivLenShort, 1), math.max(structPivLenShort, 1))
pivHiStruct = structPivLenLong  == 0 ? pivHi2 : pivHiDedie
pivLoStruct = structPivLenShort == 0 ? pivLo2 : pivLoDedie

var int   structBias   = 0
var float lastHiStruct = na
var float lastLoStruct = na
if structBiasReset and conditionStart
    structBias   := 0
    lastHiStruct := na
    lastLoStruct := na
if not na(pivHiStruct)
    lastHiStruct := pivHiStruct
if not na(pivLoStruct)
    lastLoStruct := pivLoStruct
if not na(lastHiStruct) and close > lastHiStruct
    structBias := 1
if not na(lastLoStruct) and close < lastLoStruct
    structBias := -1

// ─── TJR Fix A : niveau de stop structurel (extrême récent ± buffer) ─────────
structStopLongLvl  = ta.lowest(low,   stopLookback) - structBuffer
structStopShortLvl = ta.highest(high, stopLookback) + structBuffer

color CLEAR = color.rgb(0, 0, 0, 100)
boxWid1     = 0.001 * boxWid

// ─── Fix #3 : boxStyle paramétré (level + isHigh) ───────────────────────────
boxStyleVal(level, isHigh) =>
    switch boxStyle
        'TYPE 1' => level
        'TYPE 2' => isHigh ? level * (1 - boxWid1) : level * (1 + boxWid1)

lineStyle(x) =>
    switch x
        'Solid'  => line.style_solid
        'Dashed' => line.style_dashed
        'Dotted' => line.style_dotted

switchtextsize(textsize) =>
    switch textsize
        'Size: Normal' => size.normal
        'Size: Small'  => size.small
        'Size: Tiny'   => size.tiny
        'Size: Auto'   => size.auto
        'Size: Large'  => size.large

switchhalign(texthalign) =>
    switch texthalign
        'Middle' => text.align_center
        'Right'  => text.align_right
        'Left'   => text.align_left

// ─── Fix #5 : tableaux séparés pour chaque série ────────────────────────────
var levelBoxes1 = array.new_box()
var levelLines1 = array.new_line()

var levelBoxes2 = array.new_box()
var levelLines2 = array.new_line()

var swingTypes = array.new_string()

// ─── TJR Fix E : événements de fill du bar courant + setups armés ────────────
// "high"/"low" = fill d'un niveau série 2, "s1" = fill d'un niveau série 1
var string[] fillEvents = array.new_string()

var int armContLongBar  = na
var int armContShortBar = na
var int armRevLongBar   = na
var int armRevShortBar  = na

// ─── TJR Fix C : compteur d'entrées par fenêtre + suivi des ré-armements ─────
var int entriesWindow = 0
var int rearmLongBar  = na
var int rearmShortBar = na

if h1 and inRange and showhighs and longTime
    hBox  = box.new(
         prevHighIndex1,
         pivHi1 * (1 + boxWid1),
         bar_index,
         boxStyleVal(pivHi1, true),
         border_color = na,
         bgcolor      = showBoxes ? sellboxCol : CLEAR,
         text_halign  = switchhalign(texthalign),
         text_valign  = text.align_center,
         text_color   = chart.fg_color,
         text_size    = switchtextsize(labelsize))
    hLine = line.new(prevHighIndex1, pivHi1, bar_index, pivHi1,
         color = showSwingLines ? sellcol : CLEAR,
         style = lineStyle(lineStyle),
         width = lineWid)
    array.push(levelBoxes1, hBox)
    array.push(levelLines1, hLine)

if l1 and inRange and showlows and shortTime
    lBox  = box.new(
         prevLowIndex1,
         pivLo1 * (1 - boxWid1),
         bar_index,
         boxStyleVal(pivLo1, false),
         border_color = na,
         bgcolor      = showBoxes ? buyboxCol : CLEAR,
         text_halign  = switchhalign(texthalign),
         text_valign  = text.align_center,
         text_color   = chart.fg_color,
         text_size    = switchtextsize(labelsize))
    lLine = line.new(prevLowIndex1, pivLo1, bar_index, pivLo1,
         color = showSwingLines ? buycol : CLEAR,
         style = lineStyle(lineStyle),
         width = lineWid)
    array.push(levelBoxes1, lBox)
    array.push(levelLines1, lLine)

if h2 and inRange and showhighs
    hBox2  = box.new(
         prevHighIndex2,
         pivHi2 * (1 + boxWid1),
         bar_index,
         boxStyleVal(pivHi2, true),
         border_color = na,
         bgcolor      = showBoxes ? sellboxCol : CLEAR,
         text_halign  = switchhalign(texthalign),
         text_valign  = text.align_center,
         text_color   = chart.fg_color,
         text_size    = switchtextsize(labelsize))
    hLine2 = line.new(prevHighIndex2, pivHi2, bar_index, pivHi2,
         color = color.orange,
         width = 2)
    array.push(levelBoxes2, hBox2)
    array.push(levelLines2, hLine2)
    array.push(swingTypes, "high")

if l2 and inRange and showlows
    lBox2  = box.new(
         prevLowIndex2,
         pivLo2 * (1 - boxWid1),
         bar_index,
         boxStyleVal(pivLo2, false),
         border_color = na,
         bgcolor      = showBoxes ? buyboxCol : CLEAR,
         text_halign  = switchhalign(texthalign),
         text_valign  = text.align_center,
         text_color   = chart.fg_color,
         text_size    = switchtextsize(labelsize))
    lLine2 = line.new(prevLowIndex2, pivLo2, bar_index, pivLo2,
         color = color.blue,
         width = 2)
    array.push(levelBoxes2, lBox2)
    array.push(levelLines2, lLine2)
    array.push(swingTypes, "low")

// ─── TJR Fix E : manageLevel ne prend plus les trades, il signale les fills ──
manageLevel(boxes, lines, seriesId) =>
    sz = array.size(boxes)
    if sz > 0
        for i = 0 to sz - 1
            j = sz - 1 - i
            b     = array.get(boxes, j)
            ln    = array.get(lines, j)
            level = line.get_y2(ln)

            filled = (bodyHigh >= level and bodyLow <= level)

            if filled and extendtilfilled and not hidefilled
                array.remove(lines, j)
                array.remove(boxes, j)

                if seriesId == 2
                    swingType = array.get(swingTypes, j)
                    array.remove(swingTypes, j)
                    array.push(fillEvents, swingType)
                else
                    array.push(fillEvents, "s1")

                continue

            box.set_right(b, bar_index + 1)
            line.set_x2(ln, bar_index + 1)

            if not swingTime
                array.remove(lines, j)
                array.remove(boxes, j)
                if seriesId == 2
                    array.remove(swingTypes, j)
                line.delete(ln)
                box.delete(b)

// ─── Application sur les deux séries ─────────────────────────────────────────
array.clear(fillEvents)
manageLevel(levelBoxes1, levelLines1, 1)
manageLevel(levelBoxes2, levelLines2, 2)

// ─── TJR : armement des setups sur fill de niveau ────────────────────────────
if conditionStart
    armContLongBar  := na
    armContShortBar := na
    armRevLongBar   := na
    armRevShortBar  := na
    entriesWindow   := 0
    rearmLongBar    := na
    rearmShortBar   := na

fillS2High = array.includes(fillEvents, "high")
fillS2Low  = array.includes(fillEvents, "low")
fillS1     = array.includes(fillEvents, "s1")
anyFill    = array.size(fillEvents) > 0

// Armement des réversions : source sélectionnable (voir revArmSrc)
revArmFill = revArmSrc == 'Série 1 — Rejection Swing'    ? fillS1 :
     revArmSrc == 'Série 2 — Continuation Swing' ? (fillS2High or fillS2Low) : anyFill

contWindow = tradeTime and not conditionStart and lastStart <= contWinMin and not tradeTimeMidnight and not tradeTimeUSA

// ─── TEST A/B 18/07 : armement sur cassure BOS des extrêmes de session ───────
// Les setups actuels ne s'arment que sur RETEST (fill) d'un pivot mémorisé ;
// dans un BOS impulsif les niveaux sont balayés et rien ne se ré-arme (cas du
// 17/07 : short 15h33 et rejection long 15h48 invisibles). Ici : la clôture
// au-delà du plus bas/plus haut de session (depuis la bougie de référence)
// arme la continuation (fenêtre BOS sans exclusion USA) et la réversion
// (rejection dans les armBars bougies suivant la cassure). Filtres de
// qualité (volCond, muchSell, mèche, ATR) inchangés.
var float sessLo = na
var float sessHi = na
bosDown = not conditionStart and not na(sessLo) and close < sessLo
bosUp   = not conditionStart and not na(sessHi) and close > sessHi
if conditionStart
    sessLo := low
    sessHi := high
else
    sessLo := math.min(nz(sessLo, low), low)
    sessHi := math.max(nz(sessHi, high), high)

bosContWindow = tradeTime and not conditionStart and lastStart <= contWinMin and not tradeTimeMidnight

if fillS2High and contWindow
    armContLongBar := bar_index
if fillS2Low and contWindow
    armContShortBar := bar_index
if revArmFill and longTime
    armRevLongBar := bar_index
if revArmFill and shortTime
    armRevShortBar := bar_index

if bosUp and bosContWindow
    armContLongBar := bar_index
if bosDown and bosContWindow
    armContShortBar := bar_index
if bosDown and longTime
    armRevLongBar := bar_index
if bosUp and shortTime
    armRevShortBar := bar_index

// ─── TJR Fix C : re-entrée après SL perdant si la thèse reverse est intacte ──
bool justLost = strategy.position_size == 0 and strategy.position_size[1] != 0
     and strategy.closedtrades > 0
     and strategy.closedtrades.profit(strategy.closedtrades - 1) < 0
if justLost and reEnterAfterLoss
    if longTime
        armRevLongBar := bar_index
        rearmLongBar  := bar_index
    if shortTime
        armRevShortBar := bar_index
        rearmShortBar  := bar_index

armOk(int b) =>
    not na(b) and bar_index - b <= armBars

liteArmOk(int b) =>
    not na(b) and bar_index - b <= reArmBars

// Fix D : long seulement si structure haussière confirmée, short si baissière
structLongOk  = not useStructFilterLong or structBias == 1
structShortOk = not useStructFilterShort or structBias == -1

// Continuation : uniquement dans le sens de la bougie de référence
refDirLongOk  = not useRefDir or refBull
refDirShortOk = not useRefDir or refBear

// Réversion : confirmation renforcée du signal
// 'Engulfante' : le corps couvre tout le corps de la bougie précédente
// 'Cassure 2 bougies' : clôture au-delà des extrêmes des 2 dernières bougies
engulfCond  = bodyHigh >= math.max(open[1], close[1]) and bodyLow <= math.min(open[1], close[1])
break2Long  = close > math.max(high[1], high[2])
break2Short = close < math.min(low[1], low[2])
revOkLong   = revConfirm == 'Aucune' or (revConfirm == 'Engulfante' ? engulfCond : break2Long)
revOkShort  = revConfirm == 'Aucune' or (revConfirm == 'Engulfante' ? engulfCond : break2Short)

// Fix B : RR calculé sur le risque réel jusqu'au stop structurel
// (fallback : filtre sp original quand le stop structurel est désactivé)
riskLongNow  = math.min(math.max(close - structStopLongLvl,  minStopPts), maxStopPts)
riskShortNow = math.min(math.max(structStopShortLvl - close, minStopPts), maxStopPts)
rrLongOk  = useStructStop ? (openValue - close) >= riskLongNow  * minRR : (openValue - close) >= sp
rrShortOk = useStructStop ? (close - openValue) >= riskShortNow * minRR : (close - openValue) >= sp

// ─── Webhook : construction et envoi du payload JSON ─────────────────────────
// SL/TP calculés au moment du signal avec close comme prix d'entrée estimé
// (l'ordre marché est rempli à la bougie suivante : léger écart possible).
// Le serveur pose les brackets stop/TP chez Tradovate à partir de ces niveaux.
whNum(float v) =>
    na(v) ? 'null' : str.tostring(math.round_to_mintick(v))

whAlert(string action, float slLvl, float tpLvl) =>
    if useWebhook
        msg = '{"secret":"' + whSecret
         + '","strategy":"' + whStrat
         + '","symbol":"' + syminfo.root
         + '","ticker":"' + syminfo.tickerid
         + '","action":"' + action
         + '","tradeType":"' + tradeType
         + '","qty":' + str.tostring(qtyIn)
         + ',"price":' + str.tostring(math.round_to_mintick(close))
         + ',"stopLoss":' + whNum(slLvl)
         + ',"takeProfit":' + whNum(tpLvl)
         + ',"time":"' + str.format_time(timenow, 'yyyy-MM-dd HH:mm:ss', 'Europe/Paris') + '"}'
        alert(msg, alert.freq_once_per_bar)

// TP plafonné par la clôture au profit fixe (même logique que la gestion d'exit)
whCapProfit(float tpLvl, bool isLong) =>
    if useProfitClose
        off = profitCloseUsd / (syminfo.pointvalue * qtyIn)
        lim = isLong ? close + off : close - off
        na(tpLvl) ? lim : (isLong ? math.min(tpLvl, lim) : math.max(tpLvl, lim))
    else
        tpLvl

// À appeler APRÈS l'affectation de tradeType dans chaque bloc d'entrée
whEntryLong() =>
    isCross = tradeType == 'crossContinue' or tradeType == 'crossSimple'
    slL = isCross ? x2 : close - (useStructStop ? riskLongNow : sp)
    tpL = isCross ? lastPeriod :
         tradeType == 'continue' ? close + tp :
         revTP == '1,5 ATR' ? close + a :
         revTP == 'Bord proche zone FP' ? zoneLow : openValue
    whAlert('buy', slL, whCapProfit(tpL, true))

whEntryShort() =>
    isCross = tradeType == 'crossContinue' or tradeType == 'crossSimple'
    slS = isCross ? x : close + (useStructStop ? riskShortNow : sp)
    tpS = isCross ? lastPeriod :
         tradeType == 'continue' ? close - tp :
         revTP == '1,5 ATR' ? close - a :
         revTP == 'Bord proche zone FP' ? zoneHigh : openValue
    whAlert('sell', slS, whCapProfit(tpS, false))

// ── Objectif d'évaluation atteint → flatten + blocage définitif ──────
// Latch : une fois le plafond de gain cumulé franchi, on ferme la position de
// CE compte (flatten via webhook si actif) et on bloque toutes les entrées.
// Astuce : les 6 blocs d'entrée exigent tous « not entered » ; initialiser
// entered à true les neutralise sans toucher à leurs conditions.
var bool evalCapReached = false
if evalAccount and not evalCapReached and strategy.netprofit >= maxGainEval
    evalCapReached := true
    strategy.cancel_all()
    if strategy.position_size != 0
        whAlert('flatten', float(na), float(na))
        strategy.close_all(comment="Objectif éval atteint")

// ─── TJR : entrées — confirmation acceptée jusqu'à armBars bougies après le fill ─
bool entered = evalCapReached
wickOkLong  = not (highWickSize > bodySize * 0.4)
wickOkShort = not (lowWickSize > bodySize * 0.4)

// Continuation long
if armOk(armContLongBar) and not entered and strategy.position_size == 0 and continuePeriod
 and entriesWindow < maxEntriesWin
 and refDirLongOk
 and tradeTime and candleBuy and wickOkLong and close > high[1] and structLongOk
    strategy.entry("Long", strategy.long, qty = qtyIn)
    if swingTimeUSA
        tradeType := "continue"
    else if lastPeriod < close
        tradeType := "continue"
    else
        tradeType := "crossContinue"
    label.new(bar_index, high, text=tradeType)
    whEntryLong()
    armContLongBar := na
    entered := true
    entriesWindow += 1

// Continuation short
if armOk(armContShortBar) and not entered and strategy.position_size == 0 and continuePeriod
 and entriesWindow < maxEntriesWin
 and refDirShortOk
 and tradeTime and candleSell and wickOkShort and close < low[1] and structShortOk
    strategy.entry("Short", strategy.short, qty = qtyIn)
    if swingTimeUSA
        tradeType := "continue"
    else if lastPeriod > close
        tradeType := "continue"
    else
        tradeType := "crossContinue"
    label.new(bar_index, high, text=tradeType)
    whEntryShort()
    armContShortBar := na
    entered := true
    entriesWindow += 1

// ─── Reverse trade long : cible = zone FP, filtre RR structurel ──────────────
if armOk(armRevLongBar) and not entered and strategy.position_size == 0
 and entriesWindow < maxEntriesWin
 and longTime
 and candleBuy
 and canTrade
 and volCond
 and not tooMuchWick
 and not muchSell
 and atrFilter
 and close > high[1]
 and revOkLong
 and rrLongOk
 and structLongOk
    strategy.entry("Long", strategy.long, qty = qtyIn)
    if swingTimeUSA
        tradeType := "simple"
    else if lastPeriod < close
        tradeType := "simple"
    else
        tradeType := "crossSimple"
    label.new(bar_index, high, text=tradeType)
    whEntryLong()
    armRevLongBar := na
    entered := true
    entriesWindow += 1

// ─── Reverse trade short : cible = zone FP, filtre RR structurel ─────────────
if armOk(armRevShortBar) and not entered and strategy.position_size == 0
 and entriesWindow < maxEntriesWin
 and shortTime
 and candleSell
 and canTrade
 and volCond
 and not tooMuchWick
 and not muchBuy
 and atrFilter
 and close < low[1]
 and revOkShort
 and rrShortOk
 and structShortOk
    strategy.entry("Short", strategy.short, qty = qtyIn)
    if swingTimeUSA
        tradeType := "simple"
    else if lastPeriod > close
        tradeType := "simple"
    else
        tradeType := "crossSimple"
    label.new(bar_index, high, text=tradeType)
    whEntryShort()
    armRevShortBar := na
    entered := true
    entriesWindow += 1

// ─── Re-entrée allégée après SL : bougie + cassure + position FP uniquement ──
// La thèse a déjà été validée à la première entrée : on ne ré-exige ni volume,
// ni wick, ni ATR, ni RR — seulement la confirmation directionnelle.
if liteReentry and reEnterAfterLoss and liteArmOk(rearmLongBar) and not entered
 and strategy.position_size == 0
 and entriesWindow < maxEntriesWin
 and longTime
 and candleBuy
 and canTrade
 and close > high[1]
 and structLongOk
    strategy.entry("Long", strategy.long, qty = qtyIn)
    if swingTimeUSA
        tradeType := "simple"
    else if lastPeriod < close
        tradeType := "simple"
    else
        tradeType := "crossSimple"
    label.new(bar_index, high, text="reentry " + tradeType)
    whEntryLong()
    rearmLongBar := na
    entered := true
    entriesWindow += 1

if liteReentry and reEnterAfterLoss and liteArmOk(rearmShortBar) and not entered
 and strategy.position_size == 0
 and entriesWindow < maxEntriesWin
 and shortTime
 and candleSell
 and canTrade
 and close < low[1]
 and structShortOk
    strategy.entry("Short", strategy.short, qty = qtyIn)
    if swingTimeUSA
        tradeType := "simple"
    else if lastPeriod > close
        tradeType := "simple"
    else
        tradeType := "crossSimple"
    label.new(bar_index, high, text="reentry " + tradeType)
    whEntryShort()
    rearmShortBar := na
    entered := true
    entriesWindow += 1

// ─── Debug re-entrées : compteurs d'échec par filtre pendant le ré-armement ──
var int dbgLbars = 0
var int dbgSbars = 0
var int[] dbgL = array.new_int(10, 0)
var int[] dbgS = array.new_int(10, 0)

dbgCount(arr, idx, ok) =>
    if not ok
        array.set(arr, idx, array.get(arr, idx) + 1)

if debugRearm and not na(rearmLongBar) and bar_index - rearmLongBar <= reArmBars and strategy.position_size == 0
    dbgLbars += 1
    dbgCount(dbgL, 0, longTime)
    dbgCount(dbgL, 1, candleBuy)
    dbgCount(dbgL, 2, close > high[1])
    dbgCount(dbgL, 3, volCond)
    dbgCount(dbgL, 4, not tooMuchWick)
    dbgCount(dbgL, 5, not muchSell)
    dbgCount(dbgL, 6, atrFilter)
    dbgCount(dbgL, 7, rrLongOk)
    dbgCount(dbgL, 8, canTrade)
    dbgCount(dbgL, 9, structLongOk)

if debugRearm and not na(rearmShortBar) and bar_index - rearmShortBar <= reArmBars and strategy.position_size == 0
    dbgSbars += 1
    dbgCount(dbgS, 0, shortTime)
    dbgCount(dbgS, 1, candleSell)
    dbgCount(dbgS, 2, close < low[1])
    dbgCount(dbgS, 3, volCond)
    dbgCount(dbgS, 4, not tooMuchWick)
    dbgCount(dbgS, 5, not muchBuy)
    dbgCount(dbgS, 6, atrFilter)
    dbgCount(dbgS, 7, rrShortOk)
    dbgCount(dbgS, 8, canTrade)
    dbgCount(dbgS, 9, structShortOk)

var table dbgTbl = na
if debugRearm and barstate.islast
    dbgTbl := table.new(position.bottom_right, 3, 11, bgcolor=color.new(color.black, 20), border_width=1, border_color=color.gray)
    dbgNames = array.from("fenetre", "bougie", "cassure", "volume", "wick", "tend30m", "atrExp", "RR", "canTrade", "struct")
    table.cell(dbgTbl, 0, 0, "Echecs re-entree", text_color=color.white, text_size=size.small)
    table.cell(dbgTbl, 1, 0, "L /" + str.tostring(dbgLbars), text_color=color.white, text_size=size.small)
    table.cell(dbgTbl, 2, 0, "S /" + str.tostring(dbgSbars), text_color=color.white, text_size=size.small)
    for i = 0 to 9
        table.cell(dbgTbl, 0, i + 1, array.get(dbgNames, i), text_color=color.white, text_size=size.small)
        table.cell(dbgTbl, 1, i + 1, str.tostring(array.get(dbgL, i)), text_color=color.white, text_size=size.small)
        table.cell(dbgTbl, 2, i + 1, str.tostring(array.get(dbgS, i)), text_color=color.white, text_size=size.small)

// ─── Nettoyage si tableaux trop grands ───────────────────────────────────────
trimArray(boxes, lines) =>
    while array.size(boxes) >= 500
        b  = array.get(boxes, 0)
        ln = array.get(lines, 0)
        box.delete(b)
        line.delete(ln)
        array.remove(boxes, 0)
        array.remove(lines, 0)

trimArray(levelBoxes1, levelLines1)
trimArray(levelBoxes2, levelLines2)

// ─── Bulles ───────────────────────────────────────────────────────────────────
plotshape(tradeTime and showhighs and showBubbles and h1 ? high[swingSizeR1] : na,
     style    = shape.circle,
     location = location.absolute,
     offset   = -swingSizeR1,
     color    = sellcolB,
     size     = size.tiny)

plotshape(tradeTime and showlows and showBubbles and l1 ? low[swingSizeR1] : na,
     style    = shape.circle,
     location = location.absolute,
     offset   = -swingSizeR1,
     color    = buycolB,
     size     = size.tiny)

plotshape(h2 ? high[swingSizeR2] : na,
     location = location.absolute,
     offset   = -swingSizeR2,
     style    = shape.circle,
     color    = color.orange)

plotshape(l2 ? low[swingSizeR2] : na,
     location = location.absolute,
     offset   = -swingSizeR2,
     style    = shape.circle,
     color    = color.blue)


// ─── Gestion SL/TP selon le type de trade ────────────────────────────────────

// Fix A : distance de stop structurelle bornée [min, max], sinon sp ATR
longStopDist(ep) =>
    useStructStop ? math.min(math.max(ep - structStopLongLvl, minStopPts), maxStopPts) : sp

shortStopDist(ep) =>
    useStructStop ? math.min(math.max(structStopShortLvl - ep, minStopPts), maxStopPts) : sp

// Continuation : SL structurel (ou ATR), TP ATR standard, une seule entrée par session
if tradeType == "continue"
    if strategy.position_size > 0 and na(entry_price)
        entry_price := strategy.position_avg_price
        stop_price := entry_price - longStopDist(entry_price)
        tp_price := entry_price + tp
        beTarget := entry_price + (entry_price - stop_price)
        continuePeriod := false

    if strategy.position_size < 0 and na(entry_price)
        entry_price := strategy.position_avg_price
        stop_price := entry_price + shortStopDist(entry_price)
        tp_price := entry_price - tp
        beTarget := entry_price - (stop_price - entry_price)
        continuePeriod := false

// Reverse trade : cible selon revTP — bord proche de la zone FP (défaut),
// openValue historique, ou 1,5 x ATR5 depuis l'entrée (variable a)
if tradeType == "simple"
    if strategy.position_size > 0 and na(entry_price)
        entry_price := strategy.position_avg_price
        stop_price := entry_price - longStopDist(entry_price)
        tp_price := revTP == '1,5 ATR' ? entry_price + a : revTP == 'Bord proche zone FP' ? zoneLow : openValue
        beTarget := entry_price + (entry_price - stop_price)

    if strategy.position_size < 0 and na(entry_price)
        entry_price := strategy.position_avg_price
        stop_price := entry_price + shortStopDist(entry_price)
        tp_price := revTP == '1,5 ATR' ? entry_price - a : revTP == 'Bord proche zone FP' ? zoneHigh : openValue
        beTarget := entry_price - (stop_price - entry_price)

if tradeType == "crossContinue"
    if strategy.position_size != 0 and na(minAtrUp) and na(minAtrDown) and continuePeriod
        minAtrUp := x
        minAtrDown := x2
        avgP = strategy.position_avg_price
        beTarget := strategy.position_size > 0 ? avgP + (avgP - minAtrDown) : avgP - (minAtrUp - avgP)
        continuePeriod := false

    if not na(x) and not na(minAtrUp)
        minAtrUp := minAtrUp > x ? x : minAtrUp
    if not na(x2) and not na(minAtrDown)
        minAtrDown := minAtrDown < x2 ? x2 : minAtrDown

    tp_price := lastPeriod

    if strategy.position_size > 0
        stop_price := minAtrDown

    if strategy.position_size < 0
        stop_price := minAtrUp


if tradeType == "crossSimple"
    if strategy.position_size != 0 and na(minAtrUp) and na(minAtrDown)
        minAtrUp := x
        minAtrDown := x2
        avgP = strategy.position_avg_price
        beTarget := strategy.position_size > 0 ? avgP + (avgP - minAtrDown) : avgP - (minAtrUp - avgP)

    if not na(x) and not na(minAtrUp)
        minAtrUp := minAtrUp > x ? x : minAtrUp

    if not na(x2) and not na(minAtrDown)
        minAtrDown := minAtrDown < x2 ? x2 : minAtrDown

    tp_price := lastPeriod

    if strategy.position_size > 0
        stop_price := minAtrDown

    if strategy.position_size < 0
        stop_price := minAtrUp

// ─── Break-even à 1R : continuations (useBE) et réversions (useBERev) ────────
// Une fois l'excursion favorable >= 1R, le stop remonte au prix d'entrée
// (ex. 24/06 02h08 continuation, 30/06 16h42 et 06/07 16h53 réversions :
// run-ups de +14 950 à +20 600 $ finis à -10 100 $)
beActive = (tradeType == "continue" or tradeType == "crossContinue") ? useBE : useBERev
if beActive and not beArmed and not na(beTarget) and strategy.position_size != 0
    if strategy.position_size > 0 and high >= beTarget
        beArmed := true
    if strategy.position_size < 0 and low <= beTarget
        beArmed := true

// Webhook : break-even armé → le serveur remonte son stop à son prix d'entrée réel
if beArmed and not beArmed[1] and strategy.position_size != 0
    whAlert('breakeven', strategy.position_avg_price, float(na))

if beArmed and strategy.position_size > 0
    stop_price := na(stop_price) ? strategy.position_avg_price : math.max(stop_price, strategy.position_avg_price)
if beArmed and strategy.position_size < 0
    stop_price := na(stop_price) ? strategy.position_avg_price : math.min(stop_price, strategy.position_avg_price)


// ─── Clôture au profit fixe (useProfitClose) : le TP est ramené au prix où le
// gain latent atteint profitCloseUsd — ordre limite, exécuté en intrabar
if useProfitClose and strategy.position_size != 0
    profitOffset = profitCloseUsd / (syminfo.pointvalue * math.abs(strategy.position_size))
    if strategy.position_size > 0
        profitLimL = strategy.position_avg_price + profitOffset
        tp_price := na(tp_price) ? profitLimL : math.min(tp_price, profitLimL)
    if strategy.position_size < 0
        profitLimS = strategy.position_avg_price - profitOffset
        tp_price := na(tp_price) ? profitLimS : math.max(tp_price, profitLimS)

// Webhook : suivi du stop suiveur (types cross / break-even) — n'envoie que les
// changements ; le niveau initial part déjà dans l'alerte d'entrée
var float whLastStop = na
if strategy.position_size == 0
    whLastStop := na
if whSendUpdates and strategy.position_size != 0 and not na(stop_price)
    stopNow = math.round_to_mintick(stop_price)
    if na(whLastStop)
        whLastStop := stopNow
    else if stopNow != whLastStop
        whAlert('modify_stop', stop_price, tp_price)
        whLastStop := stopNow

strategy.exit("SL/TP LONG", from_entry="Long", stop=stop_price, limit=tp_price)

strategy.exit("SL/TP Short", from_entry="Short", stop=stop_price, limit=tp_price)

highFP = math.max(openValue, closeValue)
lowFP = math.min(openValue, closeValue)
closeInFP = close > lowFP and close < highFP
openOutFP = not (open > lowFP and open < highFP)
fairPriceCond = closeInFP and openOutFP

// Continuation exemptée de la sortie fair price si l'option est décochée
fpExemptCont = not useFpCloseCont and (tradeType == "continue" or tradeType == "crossContinue")
if fairPriceCond and not fpExemptCont
    if strategy.position_size != 0
        whAlert('flatten', float(na), float(na))
    strategy.close_all("Fair price reached")

if conditionStart
    myLineClose := line.new(
         x1 = bar_index,
         y1 = close,
         x2 = bar_index,
         y2 = close,
         color = color.green,
         width = 2
     )

    myLineOpen := line.new(
         x1 = bar_index,
         y1 = open,
         x2 = bar_index,
         y2 = open,
         color = color.green,
         width = 2
     )



if not na(myLineClose) and tradeTime
    line.set_x2(myLineClose, bar_index)

if not na(myLineOpen) and tradeTime
    line.set_x2(myLineOpen, bar_index)