//@version=6
strategy("Forex 1H – Trendline Breakout", overlay=true,
     default_qty_type=strategy.percent_of_equity, default_qty_value=2,
     commission_type=strategy.commission.percent, commission_value=0.01,
     initial_capital=10000, calc_on_every_tick=true,
     max_lines_count=500, max_labels_count=500)

import TradingView/ta/7

// Nécessaire pour la boucle de validation (close[i] avec index dynamique)
max_bars_back(close, 2000)

// ══════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════
pivotLen    = input.int(10,   "Pivot length (barres de chaque côté)", minval=3, maxval=50,  group="Trendline",
     tooltip="10 = swing sur ±10 barres. Plus grand = pivots plus significatifs.")
minSpanBars = input.int(24,   "(obsolète — non utilisé)", minval=6,                         group="Trendline",
     tooltip="Conservé uniquement pour ne pas décaler les indices in_N sauvegardés.")
maxPivots   = input.int(10,   "(obsolète — non utilisé)",  minval=4, maxval=30,             group="Trendline",
     tooltip="Conservé uniquement pour ne pas décaler les indices in_N sauvegardés.")
maxBreakPct = input.float(3.0,"Breakout max (%)",     minval=0.1, step=0.5,                 group="Signal",
     tooltip="Cassure ignorée si close est déjà à plus de X% au-delà de la trendline.")
rvolLen     = input.int(50,   "RVOL lookback (barres)",          minval=1,                  group="Volume")
rvolAnchor  = input.timeframe("1D", "RVOL anchor TF",                                       group="Volume")
volMult     = input.float(2.0,"Seuil RVOL minimum (x)",         minval=0.5, step=0.1,       group="Volume")
atrLen      = input.int(14,   "ATR length",                      minval=1,                  group="Risque")
rrRatio     = input.float(2.0,"Risk : Reward",                   minval=0.5, step=0.5,      group="Risque")

// ─── Webhook : alertes JSON vers le dispatcher FastAPI (state_manager) ───────
// Déclarés en dernier pour ne pas décaler les indices in_N sauvegardés.
// NB : stratégie forex — le dispatcher actuel exécute sur Tradovate (futures) ;
// prévoir un backend forex côté serveur avant d'activer en réel.
useWebhook = input.bool(false, "Alertes webhook JSON", group="Webhook")
whSecret   = input.string("CHANGE_ME", "Secret partagé", group="Webhook", tooltip="Doit correspondre au secret attendu par le serveur FastAPI")
whStrat    = input.string("FOREX_1H_TL", "Identifiant stratégie", group="Webhook")

// Nouveaux inputs — déclarés après les inputs webhook pour préserver les indices in_N sauvegardés.
srDays = input.int(10, "Fenêtre S/R (jours)", minval=2, maxval=60, group="Trendline",
     tooltip="Durée de vie max d'une ligne : plus vieille que N jours, elle expire et n'est plus tracée ni cassable.")
int srWindowBars = srDays * 24               // 1H forex : ~24 barres par jour

tlValidate = input.bool(true, "Ligne propre exigée (validation A → aujourd'hui)", group="Trendline",
     tooltip="Façon LuxAlgo « Check breaks » : la trendline n'est retenue que si aucune clôture ne l'a traversée entre le premier pivot et la barre de création.")
minBarsValid = input.int(3, "Barres mini avant cassure", minval=0, group="Trendline",
     tooltip="Façon LuxAlgo « Minimal bars » : la cassure ne vaut signal que si la ligne était intacte depuis au moins N barres.")

whNum(float v) =>
    na(v) ? 'null' : str.tostring(math.round_to_mintick(v))

// La taille réelle par compte vient du serveur (accounts.json) ; qty=1 indicatif.
whAlert(string action, float slLvl, float tpLvl) =>
    if useWebhook
        msg = '{"secret":"' + whSecret
         + '","strategy":"' + whStrat
         + '","symbol":"' + syminfo.root
         + '","ticker":"' + syminfo.tickerid
         + '","action":"' + action
         + '","tradeType":"trendline"'
         + ',"qty":1'
         + ',"price":' + str.tostring(math.round_to_mintick(close))
         + ',"stopLoss":' + whNum(slLvl)
         + ',"takeProfit":' + whNum(tpLvl)
         + ',"time":"' + str.format_time(timenow, 'yyyy-MM-dd HH:mm:ss', 'Europe/Paris') + '"}'
        alert(msg, alert.freq_once_per_bar)

// ══════════════════════════════════════════════════════════════
// ATR + RVOL
// ══════════════════════════════════════════════════════════════
atr = ta.atr(atrLen)

[curVol, pastVol, _] = ta.relativeVolume(rvolLen, rvolAnchor, true, true)
relVol  = not na(curVol) and not na(pastVol) and pastVol > 0 ? curVol / pastVol : na
highVol = not na(relVol) and relVol >= volMult
rvolOk  = highVol

// ══════════════════════════════════════════════════════════════
// RÉSISTANCE — 2 pivots hauts consécutifs décroissants
//   (façon LuxAlgo Trend Lines)
//   La ligne relie le pivot précédent (A) au nouveau pivot (B).
//   Elle n'est retenue que si « propre » : aucune clôture ne l'a
//   traversée entre A et aujourd'hui. Ensuite elle est étendue
//   barre après barre, et meurt dès qu'une clôture la casse ou
//   quand elle dépasse la fenêtre S/R.
// ══════════════════════════════════════════════════════════════
ph = ta.pivothigh(high, pivotLen, pivotLen)

var int   phx1      = na
var float phy1      = na
var float descSlope = na
var float upper     = na
var int   descBirth = na
var bool  descValid = false

if not na(ph)
    int x2 = bar_index - pivotLen
    if not na(phy1) and ph < phy1
        float slope = (ph - phy1) / float(x2 - phx1)
        bool broken = false
        if tlValidate
            int span = math.min(bar_index - phx1, 2000)
            for i = 0 to span
                if close[i] > phy1 + slope * float(bar_index - i - phx1)
                    broken := true
                    break
        if not broken
            descSlope := slope
            upper     := ph + slope * float(pivotLen)   // valeur de la ligne à la barre courante
            descBirth := bar_index
            descValid := true
            // Segment historique A → B (pointillé, comme LuxAlgo)
            line.new(phx1, phy1, x2, ph, color=color.new(color.red, 40), style=line.style_dotted)
    phy1 := ph
    phx1 := x2

// Extension barre après barre (sauf à la barre de création)
if descValid and bar_index > descBirth
    upper += descSlope

// ══════════════════════════════════════════════════════════════
// SUPPORT — 2 pivots bas consécutifs croissants
//   Même mécanique, symétrique.
// ══════════════════════════════════════════════════════════════
pl = ta.pivotlow(low, pivotLen, pivotLen)

var int   plx1     = na
var float ply1     = na
var float ascSlope = na
var float lower    = na
var int   ascBirth = na
var bool  ascValid = false

if not na(pl)
    int x2 = bar_index - pivotLen
    if not na(ply1) and pl > ply1
        float slope = (pl - ply1) / float(x2 - plx1)
        bool broken = false
        if tlValidate
            int span = math.min(bar_index - plx1, 2000)
            for i = 0 to span
                if close[i] < ply1 + slope * float(bar_index - i - plx1)
                    broken := true
                    break
        if not broken
            ascSlope := slope
            lower    := pl + slope * float(pivotLen)    // valeur de la ligne à la barre courante
            ascBirth := bar_index
            ascValid := true
            line.new(plx1, ply1, x2, pl, color=color.new(color.green, 40), style=line.style_dotted)
    ply1 := pl
    plx1 := x2

if ascValid and bar_index > ascBirth
    lower += ascSlope

// Niveaux affichés / utilisés par les signaux
// na à la barre de création : coupe le tracé (linebr) pour éviter un
// connecteur vertical entre l'ancienne ligne et la nouvelle (façon
// LuxAlgo « ta.change(phslope) ? na : ... »)
float tlDesc = descValid and bar_index != descBirth ? upper : na
float tlAsc  = ascValid  and bar_index != ascBirth  ? lower : na

// ══════════════════════════════════════════════════════════════
// SIGNAUX — uniquement sur BOS FRAIS de la ligne
//   LONG  : close franchit la résistance sur CETTE barre
//           (close[1] encore en-dessous), ligne intacte depuis
//           au moins minBarsValid barres.
//   SHORT : symétrique sous le support.
//   Dans les deux cas : RVOL ≥ seuil + pas déjà en position
// ══════════════════════════════════════════════════════════════
noPosition = strategy.position_size == 0

int descAge = descValid ? bar_index - descBirth : 0
int ascAge  = ascValid  ? bar_index - ascBirth  : 0

longBreak  = descValid and descAge >= minBarsValid and close > upper and close[1] <= upper[1]
longNotFar = close <= upper * (1.0 + maxBreakPct / 100.0)
longSignal = longBreak and longNotFar and highVol and noPosition

shortBreak  = ascValid and ascAge >= minBarsValid and close < lower and close[1] >= lower[1]
shortNotFar = close >= lower * (1.0 - maxBreakPct / 100.0)
shortSignal = shortBreak and shortNotFar and highVol and noPosition

// ══════════════════════════════════════════════════════════════
// ENTRÉES / SORTIES
//   SL LONG  = résistance cassée − ATR
//   SL SHORT = support cassé     + ATR
//   TP       = close ± ATR × R:R
// ══════════════════════════════════════════════════════════════
if longSignal
    sl_l = upper - atr
    tp_l = close + atr * rrRatio
    strategy.entry("Long",  strategy.long,  comment="BRK↑")
    strategy.exit("SL/TP L", "Long",  stop=sl_l, limit=tp_l)
    whAlert('buy', sl_l, tp_l)

if shortSignal
    sl_s = lower + atr
    tp_s = close - atr * rrRatio
    strategy.entry("Short", strategy.short, comment="BRK↓")
    strategy.exit("SL/TP S", "Short", stop=sl_s, limit=tp_s)
    whAlert('sell', sl_s, tp_s)

// ══════════════════════════════════════════════════════════════
// INVALIDATION (après les signaux, pour laisser la cassure
// fraîche déclencher le trade sur sa barre)
//   - clôture au-delà de la ligne → morte
//   - plus vieille que la fenêtre S/R → expirée
// ══════════════════════════════════════════════════════════════
if descValid and (close > upper or bar_index - descBirth > srWindowBars)
    descValid := false

if ascValid and (close < lower or bar_index - ascBirth > srWindowBars)
    ascValid := false

// ══════════════════════════════════════════════════════════════
// PLOTS
// ══════════════════════════════════════════════════════════════
plot(tlDesc, "Résistance (pivots hauts)", color=color.red,   linewidth=2, style=plot.style_linebr)
plot(tlAsc,  "Support (pivots bas)",      color=color.green, linewidth=2, style=plot.style_linebr)

// Marqueurs de signal
plotshape(longSignal,  "Long",  shape.triangleup,   location.belowbar, color=color.new(color.lime, 0),   size=size.small)
plotshape(shortSignal, "Short", shape.triangledown, location.abovebar, color=color.new(color.red,  0),   size=size.small)

// Pivots (affichés avec décalage car confirmés après pivotLen barres)
plotshape(not na(ph), "Pivot High", shape.xcross, location.abovebar, color=color.new(color.red,   30), size=size.tiny, offset=-pivotLen)
plotshape(not na(pl), "Pivot Low",  shape.xcross, location.belowbar, color=color.new(color.green, 30), size=size.tiny, offset=-pivotLen)

bgcolor(highVol ? color.new(color.green, 80) : na, title="RVOL élevé")

// ══════════════════════════════════════════════════════════════
// LABEL RVOL + ATR (dernière bougie)
// ══════════════════════════════════════════════════════════════
var label infoLbl = na

if barstate.islast
    label.delete(infoLbl)
    rvolStr  = not na(relVol) ? str.tostring(relVol, "#.##") + "x" : "NA"
    atrStr   = str.tostring(atr, "#.#####")
    lblTxt   = "RVOL " + rvolStr + "\nATR  " + atrStr
    lblColor = rvolOk ? color.new(color.green, 20) : color.new(color.red, 20)
    infoLbl  := label.new(bar_index + 2, high, lblTxt,
         xloc=xloc.bar_index, yloc=yloc.price,
         color=lblColor, textcolor=color.white,
         style=label.style_label_left, size=size.normal)

// ══════════════════════════════════════════════════════════════
// TABLE DE BORD (coin haut-droit)
// ══════════════════════════════════════════════════════════════
var table dash = table.new(position.top_right, 2, 6,
     bgcolor=color.new(color.black, 50), border_color=color.new(color.gray, 30), border_width=1)

_hdr(col, row, txt) =>
    table.cell(dash, col, row, txt, bgcolor=color.new(color.navy, 10),
         text_color=color.white, text_size=size.normal)

_val(col, row, txt, bg) =>
    table.cell(dash, col, row, txt, bgcolor=bg,
         text_color=color.white, text_size=size.normal)

if barstate.islast
    _hdr(0, 0, "RVOL")
    volBg = rvolOk ? color.new(color.green, 25) : color.new(color.red, 25)
    _val(1, 0, not na(relVol) ? str.tostring(relVol, "#.##") + "x" : "—", volBg)

    _hdr(0, 1, "ATR")
    _val(1, 1, str.tostring(atr, "#.#####"), color.new(color.gray, 40))

    _hdr(0, 2, "Résistance")
    _val(1, 2, not na(tlDesc) ? str.tostring(tlDesc, "#.####") : "—", color.new(color.gray, 40))

    _hdr(0, 3, "Support")
    _val(1, 3, not na(tlAsc) ? str.tostring(tlAsc, "#.####") : "—", color.new(color.gray, 40))

    _hdr(0, 4, "Position")
    posBg  = strategy.position_size != 0 ? color.new(color.blue, 25) : color.new(color.gray, 55)
    posStr = strategy.position_size > 0 ? "LONG ✓" : strategy.position_size < 0 ? "SHORT ✓" : "—"
    _val(1, 4, posStr, posBg)

    _hdr(0, 5, "R:R")
    _val(1, 5, str.tostring(rrRatio, "#.#") + ":1", color.new(color.gray, 40))
